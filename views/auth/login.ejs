<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1E3A8A, #172554);
            padding: 1rem;
        }
        .login-card {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            max-width: 400px;
            width: 100%;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        .form-input {
            width: 100%;
            padding: 0.7rem;
            border: 2px solid #E5E7EB;
            border-radius: 10px;
            font-size: 0.95rem;
            margin-bottom: 0.75rem;
            transition: border-color 0.3s;
        }
        .form-input:focus {
            outline: none;
            border-color: #1E3A8A;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }
        .btn-login {
            width: 100%;
            padding: 0.7rem;
            background: #1E3A8A;
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
        }
        .btn-login:hover {
            background: #172554;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(30, 58, 138, 0.3);
        }
        .alert-error {
            background: #FEE2E2;
            color: #991B1B;
            padding: 0.5rem;
            border-radius: 10px;
            margin-bottom: 1rem;
            text-align: center;
            border: 1px solid #FECACA;
        }
        .alert-success {
            background: #D1FAE5;
            color: #065F46;
            padding: 0.5rem;
            border-radius: 10px;
            margin-bottom: 1rem;
            text-align: center;
            border: 1px solid #A7F3D0;
        }
        .logo-icon { font-size: 3rem; display: block; }
        .logo-title { font-size: 1.8rem; color: #1E3A8A; font-weight: 800; }
        .logo-subtitle { font-size: 0.8rem; color: #6B7280; letter-spacing: 2px; }
        .register-link { text-align: center; margin-top: 1rem; font-size: 0.9rem; }
        .register-link a { color: #1E3A8A; text-decoration: none; font-weight: 600; }
        .register-link a:hover { text-decoration: underline; }
        .divider { display: flex; align-items: center; gap: 0.8rem; margin: 1rem 0; }
        .divider-line { flex: 1; height: 1px; background: #E5E7EB; }
        .divider-text { font-size: 0.8rem; color: #9CA3AF; white-space: nowrap; }
        .checkbox-label { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: #6B7280; cursor: pointer; }
        .checkbox-label input { accent-color: #1E3A8A; width: 16px; height: 16px; }
        .forgot-link { font-size: 0.85rem; color: #1E3A8A; text-decoration: none; font-weight: 500; }
        .forgot-link:hover { text-decoration: underline; }
        .actions-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem; }
        @media (max-width: 480px) {
            .login-card { padding: 1.5rem; }
            .actions-row { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <span class="logo-icon">⚽</span>
            <h1 class="logo-title">ELITE SOCCER</h1>
            <p class="logo-subtitle">Academy</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert-error">⚠️ <%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert-success">✅ <%= success %></div>
        <% } %>

        <form method="POST" action="/login">
            <input type="email" name="email" class="form-input" placeholder="Correo electrónico" required autofocus>
            <input type="password" name="password" class="form-input" placeholder="Contraseña" required>

            <div class="actions-row">
                <label class="checkbox-label">
                    <input type="checkbox" name="remember"> Recordarme
                </label>
                <a href="/forgot-password" class="forgot-link">¿Olvidaste tu contraseña?</a>
            </div>

            <button type="submit" class="btn-login">🚀 Iniciar Sesión</button>
        </form>

        <div class="divider">
            <span class="divider-line"></span>
            <span class="divider-text">¿Nuevo aquí?</span>
            <span class="divider-line"></span>
        </div>

        <div class="register-link">
            <a href="/register">📝 Crear una cuenta nueva</a>
        </div>
    </div>
</body>
</html>