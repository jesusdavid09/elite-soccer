<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
        .login-hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0A2540 0%, #1E40AF 100%);
            padding: 1rem;
        }
        .login-card {
            background: white;
            border-radius: 24px;
            padding: 2rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            animation: fadeInUp 0.6s ease;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .btn-login {
            width: 100%;
            padding: 0.75rem;
            background: linear-gradient(135deg, #1E40AF, #00AEEF);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-login:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 20px rgba(0,174,239,0.3);
        }
        .form-input {
            width: 100%;
            padding: 0.75rem;
            border: 2px solid #E5E7EB;
            border-radius: 12px;
            transition: all 0.3s;
        }
        .form-input:focus {
            outline: none;
            border-color: #00AEEF;
            box-shadow: 0 0 0 3px rgba(0,174,239,0.1);
        }
    </style>
</head>
<body>
    <div class="login-hero">
        <div class="login-card">
            <div class="text-center mb-6">
                <div class="text-6xl mb-2">⚽</div>
                <h1 class="text-2xl font-bold text-dark-blue">ELITE SOCCER</h1>
                <p class="text-sm text-gray-500">Academy</p>
            </div>
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-100 text-red-700 p-3 rounded-xl mb-4 text-center"><%= error %></div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="bg-green-100 text-green-700 p-3 rounded-xl mb-4 text-center"><%= success %></div>
            <% } %>
            
            <form method="POST" action="/login">
                <div class="mb-3">
                    <input type="email" name="email" class="form-input" placeholder="Correo electrónico" required>
                </div>
                <div class="mb-4">
                    <input type="password" name="password" class="form-input" placeholder="Contraseña" required>
                </div>
                <button type="submit" class="btn-login">Iniciar Sesión</button>
            </form>
            
            <div class="text-center mt-4">
                <a href="/register" class="text-sm text-sport-blue hover:underline">¿No tienes cuenta? Regístrate</a>
            </div>
        </div>
    </div>
</body>
</html>