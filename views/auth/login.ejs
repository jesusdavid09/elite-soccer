<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            background: linear-gradient(135deg, #1E3A8A 0%, #172554 50%, #0F172A 100%);
            position: relative;
            overflow: hidden;
        }

        /* Efecto de fondo con círculos decorativos */
        body::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 50%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
                        radial-gradient(circle at 70% 80%, rgba(59, 130, 246, 0.05) 0%, transparent 50%);
            animation: rotateBg 30s linear infinite;
            pointer-events: none;
        }

        @keyframes rotateBg {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .login-card {
            background: #FFFFFF;
            border-radius: 24px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
            animation: fadeInUp 0.6s ease;
            position: relative;
            z-index: 1;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Elementos decorativos */
        .login-card::before {
            content: '⚽';
            position: absolute;
            top: -15px;
            right: -15px;
            font-size: 3.5rem;
            opacity: 0.08;
            transform: rotate(15deg);
        }

        .login-card::after {
            content: '🏆';
            position: absolute;
            bottom: -12px;
            left: -12px;
            font-size: 2.5rem;
            opacity: 0.06;
            transform: rotate(-10deg);
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .logo-icon {
            font-size: 4rem;
            display: block;
            margin-bottom: 0.5rem;
        }

        .logo-title {
            font-family: 'Bebas Neue', cursive;
            font-size: 2rem;
            color: #1E3A8A;
            letter-spacing: 3px;
        }

        .logo-subtitle {
            font-size: 0.8rem;
            color: #6B7280;
            letter-spacing: 4px;
            text-transform: uppercase;
        }

        .form-input {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid #E5E7EB;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            color: #111827;
            background: #FFFFFF;
        }

        .form-input:focus {
            outline: none;
            border-color: #1E3A8A;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }

        .form-input::placeholder {
            color: #9CA3AF;
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: #111827;
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }

        .btn-login {
            width: 100%;
            padding: 0.75rem;
            background: #1E3A8A;
            color: #FFFFFF;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .btn-login:hover {
            background: #172554;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(30, 58, 138, 0.4);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .alert-error {
            background: #FEE2E2;
            color: #991B1B;
            padding: 0.75rem 1rem;
            border-radius: 12px;
            margin-bottom: 1rem;
            text-align: center;
            font-size: 0.9rem;
            border: 1px solid #FECACA;
        }

        .alert-success {
            background: #D1FAE5;
            color: #065F46;
            padding: 0.75rem 1rem;
            border-radius: 12px;
            margin-bottom: 1rem;
            text-align: center;
            font-size: 0.9rem;
            border: 1px solid #A7F3D0;
        }

        .register-link {
            display: block;
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.9rem;
            color: #6B7280;
        }

        .register-link a {
            color: #1E3A8A;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .register-link a:hover {
            color: #172554;
            text-decoration: underline;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.5rem 0;
        }

        .divider-line {
            flex: 1;
            height: 1px;
            background: #E5E7EB;
        }

        .divider-text {
            font-size: 0.8rem;
            color: #9CA3AF;
            font-weight: 500;
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 480px) {
            .login-card {
                padding: 1.75rem 1.25rem;
            }
            .logo-icon {
                font-size: 3rem;
            }
            .logo-title {
                font-size: 1.5rem;
            }
            .form-input {
                font-size: 0.9rem;
                padding: 0.6rem 0.9rem;
            }
            .btn-login {
                font-size: 0.9rem;
                padding: 0.6rem;
            }
            .login-card::before {
                font-size: 2.5rem;
                top: -10px;
                right: -10px;
            }
            .login-card::after {
                font-size: 2rem;
                bottom: -8px;
                left: -8px;
            }
        }
    </style>
</head>
<body>
    <div class="login-card">
        <!-- Logo -->
        <div class="text-center mb-6">
            <span class="logo-icon">⚽</span>
            <h1 class="logo-title">ELITE SOCCER</h1>
            <p class="logo-subtitle">Academy</p>
        </div>

        <!-- Mensajes de Error/Success -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert-error">
                ⚠️ <%= error %>
            </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert-success">
                ✅ <%= success %>
            </div>
        <% } %>

        <!-- Formulario de Login -->
        <form method="POST" action="/login">
            <div class="mb-4">
                <label class="form-label">📧 Correo Electrónico</label>
                <input type="email" name="email" class="form-input" placeholder="ejemplo@email.com" required autofocus>
            </div>
            <div class="mb-4">
                <label class="form-label">🔒 Contraseña</label>
                <input type="password" name="password" class="form-input" placeholder="Ingresa tu contraseña" required>
            </div>

            <!-- Opciones adicionales (opcional) -->
            <div class="flex items-center justify-between mb-4">
                <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                    <input type="checkbox" name="remember" class="form-checkbox" style="width: 16px; height: 16px; accent-color: #1E3A8A;">
                    Recordarme
                </label>
                <a href="#" class="text-sm" style="color: #1E3A8A; text-decoration: none; font-weight: 500;">¿Olvidaste tu contraseña?</a>
            </div>

            <button type="submit" class="btn-login">🚀 Iniciar Sesión</button>
        </form>

        <!-- Separador -->
        <div class="divider">
            <span class="divider-line"></span>
            <span class="divider-text">¿Nuevo aquí?</span>
            <span class="divider-line"></span>
        </div>

        <!-- Link a Registro -->
        <p class="register-link">
            <a href="/register">📝 Crear una cuenta nueva</a>
        </p>
    </div>
</body>
</html>