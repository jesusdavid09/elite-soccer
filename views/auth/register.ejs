<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1E3A8A, #172554);
            padding: 1rem;
        }
        .register-card {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            max-width: 450px;
            width: 100%;
            max-height: 98vh;
            overflow-y: auto;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        .register-card::-webkit-scrollbar { width: 4px; }
        .register-card::-webkit-scrollbar-thumb { background: #1E3A8A; border-radius: 4px; }
        .form-input, .form-select {
            width: 100%;
            padding: 0.6rem 0.8rem;
            border: 2px solid #E5E7EB;
            border-radius: 10px;
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
            transition: border-color 0.3s;
        }
        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #1E3A8A;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }
        .btn-register {
            width: 100%;
            padding: 0.7rem;
            background: #1E3A8A;
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
        }
        .btn-register:hover {
            background: #172554;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(30, 58, 138, 0.3);
        }
        .alert-error {
            background: #FEE2E2;
            color: #991B1B;
            padding: 0.5rem;
            border-radius: 10px;
            margin-bottom: 1rem;
            text-align: center;
            border: 1px solid #FECACA;
        }
        .logo-icon { font-size: 3rem; display: block; }
        .logo-title { font-size: 1.8rem; color: #1E3A8A; font-weight: 800; }
        .logo-subtitle { font-size: 0.8rem; color: #6B7280; letter-spacing: 2px; }
        .login-link { text-align: center; margin-top: 1rem; font-size: 0.9rem; }
        .login-link a { color: #1E3A8A; text-decoration: none; font-weight: 600; }
        .login-link a:hover { text-decoration: underline; }
        .section-box {
            background: #F8FAFC;
            border-radius: 12px;
            padding: 0.8rem;
            margin-bottom: 0.8rem;
            border: 1px solid #E5E7EB;
        }
        .section-title { font-weight: 600; color: #1E3A8A; margin-bottom: 0.5rem; font-size: 0.9rem; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
        .checkbox-label { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: #6B7280; cursor: pointer; }
        .checkbox-label input { accent-color: #1E3A8A; width: 16px; height: 16px; }
        .divider { display: flex; align-items: center; gap: 0.8rem; margin: 1rem 0; }
        .divider-line { flex: 1; height: 1px; background: #E5E7EB; }
        .divider-text { font-size: 0.8rem; color: #9CA3AF; white-space: nowrap; }
        @media (max-width: 480px) {
            .register-card { padding: 1.5rem; }
            .grid-2 { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="text-center mb-4">
            <span class="logo-icon">⚽</span>
            <h1 class="logo-title">ELITE SOCCER</h1>
            <p class="logo-subtitle">Academy</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert-error">⚠️ <%= error %></div>
        <% } %>

        <form method="POST" action="/register">
            <!-- Datos de acceso -->
            <div class="section-box">
                <div class="section-title">📝 Datos de acceso</div>
                <input type="text" name="full_name" class="form-input" placeholder="Nombre completo *" required>
                <input type="email" name="email" class="form-input" placeholder="Correo electrónico *" required>
                <input type="password" name="password" class="form-input" placeholder="Contraseña (mínimo 6 caracteres) *" minlength="6" required>
            </div>

            <!-- Datos deportivos -->
            <div id="playerFields" class="section-box">
                <div class="section-title">⚽ Datos deportivos</div>
                <div class="grid-2">
                    <input type="number" name="jersey_number" id="jersey_number" class="form-input" placeholder="Número *" min="1" max="99">
                    <input type="number" name="age" id="age" class="form-input" placeholder="Edad" min="1" max="99">
                </div>
                <select name="position" id="position" class="form-select">
                    <option value="">Seleccionar posición *</option>
                    <option value="Portero">🧤 Portero</option>
                    <option value="Defensa Central">🛡️ Defensa Central</option>
                    <option value="Lateral Derecho">➡️ Lateral Derecho</option>
                    <option value="Lateral Izquierdo">⬅️ Lateral Izquierdo</option>
                    <option value="Mediocampista">🎯 Mediocampista</option>
                    <option value="Delantero">⚽ Delantero</option>
                </select>
                <input type="text" name="phone" id="phone" class="form-input" placeholder="Teléfono (opcional)">
            </div>

            <!-- Tipo de cuenta -->
            <div class="section-box">
                <div class="section-title">👥 Tipo de cuenta</div>
                <select name="role" id="roleSelect" class="form-select">
                    <option value="player">👤 Jugador</option>
                    <option value="coach">👨‍🏫 Entrenador</option>
                </select>
                <div id="coachKeyDiv" style="display: none; margin-top: 0.5rem;">
                    <input type="password" name="coach_key" class="form-input" placeholder="Clave de entrenador *">
                </div>
            </div>

            <!-- Términos -->
            <div class="mb-3">
                <label class="checkbox-label">
                    <input type="checkbox" name="terms" required>
                    Acepto los <a href="#" style="color: #1E3A8A; text-decoration: none; font-weight: 600;">términos y condiciones</a>
                </label>
            </div>

            <button type="submit" class="btn-register">🚀 Registrarse</button>
        </form>

        <div class="divider">
            <span class="divider-line"></span>
            <span class="divider-text">¿Ya tienes cuenta?</span>
            <span class="divider-line"></span>
        </div>

        <div class="login-link">
            <a href="/login">🔑 Iniciar Sesión</a>
        </div>
    </div>

    <script>
        // Mostrar/ocultar campos según rol
        const roleSelect = document.getElementById('roleSelect');
        const playerFields = document.getElementById('playerFields');
        const coachKeyDiv = document.getElementById('coachKeyDiv');
        
        roleSelect.addEventListener('change', function() {
            const isCoach = this.value === 'coach';
            playerFields.style.display = isCoach ? 'none' : 'block';
            coachKeyDiv.style.display = isCoach ? 'block' : 'none';
            
            // Habilitar/deshabilitar campos de jugador
            const inputs = playerFields.querySelectorAll('input, select');
            inputs.forEach(input => input.disabled = isCoach);
        });
        
        // Ejecutar al cargar
        if (roleSelect.value === 'coach') {
            playerFields.style.display = 'none';
            coachKeyDiv.style.display = 'block';
        }
    </script>
</body>
</html>