<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            background: linear-gradient(135deg, #1E3A8A 0%, #172554 50%, #0F172A 100%);
            position: relative;
            overflow: hidden;
        }

        /* Efecto de fondo con círculos decorativos */
        body::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 50%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
                        radial-gradient(circle at 70% 80%, rgba(59, 130, 246, 0.05) 0%, transparent 50%);
            animation: rotateBg 30s linear infinite;
            pointer-events: none;
        }

        @keyframes rotateBg {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .register-card {
            background: #FFFFFF;
            border-radius: 24px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
            animation: fadeInUp 0.6s ease;
            position: relative;
            z-index: 1;
            border: 1px solid rgba(255, 255, 255, 0.1);
            max-height: 95vh;
            overflow-y: auto;
        }

        /* Scroll personalizado para la tarjeta */
        .register-card::-webkit-scrollbar {
            width: 4px;
        }

        .register-card::-webkit-scrollbar-track {
            background: #F3F4F6;
            border-radius: 4px;
        }

        .register-card::-webkit-scrollbar-thumb {
            background: #1E3A8A;
            border-radius: 4px;
        }

        /* Elementos decorativos */
        .register-card::before {
            content: '⚽';
            position: absolute;
            top: -15px;
            right: -15px;
            font-size: 3.5rem;
            opacity: 0.08;
            transform: rotate(15deg);
        }

        .register-card::after {
            content: '🏆';
            position: absolute;
            bottom: -12px;
            left: -12px;
            font-size: 2.5rem;
            opacity: 0.06;
            transform: rotate(-10deg);
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .logo-icon {
            font-size: 3.5rem;
            display: block;
            margin-bottom: 0.25rem;
        }

        .logo-title {
            font-family: 'Bebas Neue', cursive;
            font-size: 1.75rem;
            color: #1E3A8A;
            letter-spacing: 3px;
        }

        .logo-subtitle {
            font-size: 0.75rem;
            color: #6B7280;
            letter-spacing: 4px;
            text-transform: uppercase;
        }

        .form-input, .form-select {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid #E5E7EB;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            color: #111827;
            background: #FFFFFF;
        }

        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #1E3A8A;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }

        .form-input::placeholder {
            color: #9CA3AF;
        }

        .form-input:disabled, .form-select:disabled {
            background: #F3F4F6;
            cursor: not-allowed;
            opacity: 0.6;
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: #111827;
            font-size: 0.85rem;
            margin-bottom: 0.4rem;
        }

        .btn-register {
            width: 100%;
            padding: 0.75rem;
            background: #1E3A8A;
            color: #FFFFFF;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
            margin-top: 0.5rem;
        }

        .btn-register:hover {
            background: #172554;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(30, 58, 138, 0.4);
        }

        .btn-register:active {
            transform: translateY(0);
        }

        .alert-error {
            background: #FEE2E2;
            color: #991B1B;
            padding: 0.75rem 1rem;
            border-radius: 12px;
            margin-bottom: 1rem;
            text-align: center;
            font-size: 0.9rem;
            border: 1px solid #FECACA;
        }

        .alert-success {
            background: #D1FAE5;
            color: #065F46;
            padding: 0.75rem 1rem;
            border-radius: 12px;
            margin-bottom: 1rem;
            text-align: center;
            font-size: 0.9rem;
            border: 1px solid #A7F3D0;
        }

        .login-link {
            display: block;
            text-align: center;
            margin-top: 1.25rem;
            font-size: 0.9rem;
            color: #6B7280;
        }

        .login-link a {
            color: #1E3A8A;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .login-link a:hover {
            color: #172554;
            text-decoration: underline;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.25rem 0;
        }

        .divider-line {
            flex: 1;
            height: 1px;
            background: #E5E7EB;
        }

        .divider-text {
            font-size: 0.75rem;
            color: #9CA3AF;
            font-weight: 500;
        }

        .section-box {
            background: #F8FAFC;
            border-radius: 16px;
            padding: 1rem 1.25rem;
            margin-bottom: 1rem;
            border: 1px solid #E5E7EB;
        }

        .section-title {
            font-weight: 600;
            font-size: 0.85rem;
            color: #1E3A8A;
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }

        .form-checkbox {
            width: 16px;
            height: 16px;
            accent-color: #1E3A8A;
            cursor: pointer;
        }

        .checkbox-label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            color: #6B7280;
            cursor: pointer;
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 500px) {
            .register-card {
                padding: 1.5rem 1.25rem;
                max-height: 90vh;
            }
            .grid-2 {
                grid-template-columns: 1fr;
            }
            .logo-icon {
                font-size: 2.75rem;
            }
            .logo-title {
                font-size: 1.5rem;
            }
            .form-input, .form-select {
                font-size: 0.85rem;
                padding: 0.6rem 0.85rem;
            }
            .btn-register {
                font-size: 0.9rem;
                padding: 0.6rem;
            }
            .register-card::before {
                font-size: 2.5rem;
                top: -10px;
                right: -10px;
            }
            .register-card::after {
                font-size: 2rem;
                bottom: -8px;
                left: -8px;
            }
            .section-box {
                padding: 0.75rem 1rem;
            }
        }

        @media (max-width: 380px) {
            .register-card {
                padding: 1rem;
            }
            .logo-icon {
                font-size: 2.25rem;
            }
            .logo-title {
                font-size: 1.25rem;
            }
        }
    </style>
</head>
<body>
    <div class="register-card">
        <!-- Logo -->
        <div class="text-center mb-4">
            <span class="logo-icon">⚽</span>
            <h1 class="logo-title">ELITE SOCCER</h1>
            <p class="logo-subtitle">Academy</p>
        </div>

        <!-- Mensajes de Error -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert-error">
                ⚠️ <%= error %>
            </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert-success">
                ✅ <%= success %>
            </div>
        <% } %>

        <!-- Formulario de Registro -->
        <form method="POST" action="/register">
            <!-- Datos de acceso -->
            <div class="section-box">
                <div class="section-title">📝 Datos de acceso</div>
                <div class="mb-3">
                    <label class="form-label">Nombre completo *</label>
                    <input type="text" name="full_name" class="form-input" placeholder="Ej: Juan Pérez" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Correo electrónico *</label>
                    <input type="email" name="email" class="form-input" placeholder="ejemplo@email.com" required>
                </div>
                <div>
                    <label class="form-label">Contraseña *</label>
                    <input type="password" name="password" class="form-input" placeholder="Mínimo 6 caracteres" minlength="6" required>
                </div>
            </div>

            <!-- Datos deportivos (solo para jugadores) -->
            <div id="playerFields" class="section-box">
                <div class="section-title">⚽ Datos deportivos</div>
                <div class="grid-2">
                    <div>
                        <label class="form-label">Número de camiseta</label>
                        <input type="number" name="jersey_number" id="jersey_number" class="form-input" placeholder="Ej: 10" min="1" max="99">
                    </div>
                    <div>
                        <label class="form-label">Edad</label>
                        <input type="number" name="age" id="age" class="form-input" placeholder="Ej: 25" min="1" max="99">
                    </div>
                </div>
                <div class="mt-3">
                    <label class="form-label">Posición</label>
                    <select name="position" id="position" class="form-select">
                        <option value="">Seleccionar posición</option>
                        <option value="Portero">🧤 Portero</option>
                        <option value="Defensa Central">🛡️ Defensa Central</option>
                        <option value="Lateral Derecho">➡️ Lateral Derecho</option>
                        <option value="Lateral Izquierdo">⬅️ Lateral Izquierdo</option>
                        <option value="Mediocampista">🎯 Mediocampista</option>
                        <option value="Delantero">⚽ Delantero</option>
                    </select>
                </div>
                <div class="mt-3">
                    <label class="form-label">Teléfono (opcional)</label>
                    <input type="text" name="phone" id="phone" class="form-input" placeholder="Ej: 555-1234">
                </div>
            </div>

            <!-- Tipo de cuenta -->
            <div class="section-box">
                <div class="section-title">👥 Tipo de cuenta</div>
                <select name="role" id="roleSelect" class="form-select">
                    <option value="player">👤 Jugador</option>
                    <option value="coach">👨‍🏫 Entrenador</option>
                </select>
                <div id="coachKeyDiv" style="display: none; margin-top: 1rem;">
                    <label class="form-label">🔑 Clave de entrenador</label>
                    <input type="password" name="coach_key" class="form-input" placeholder="Ingresa la clave de entrenador">
                </div>
            </div>

            <!-- Términos y condiciones -->
            <div class="mb-4">
                <label class="checkbox-label">
                    <input type="checkbox" name="terms" class="form-checkbox" required>
                    Acepto los <a href="#" style="color: #1E3A8A; text-decoration: none; font-weight: 600;">términos y condiciones</a>
                </label>
            </div>

            <button type="submit" class="btn-register">🚀 Registrarse</button>
        </form>

        <!-- Separador -->
        <div class="divider">
            <span class="divider-line"></span>
            <span class="divider-text">¿Ya tienes cuenta?</span>
            <span class="divider-line"></span>
        </div>

        <!-- Link a Login -->
        <p class="login-link">
            <a href="/login">🔑 Iniciar Sesión</a>
        </p>
    </div>

    <script>
        const roleSelect = document.getElementById('roleSelect');
        const playerFields = document.getElementById('playerFields');
        const coachKeyDiv = document.getElementById('coachKeyDiv');
        const jerseyInput = document.getElementById('jersey_number');
        const positionSelect = document.getElementById('position');
        const ageInput = document.getElementById('age');
        const phoneInput = document.getElementById('phone');

        function updateForm() {
            if (roleSelect.value === 'coach') {
                playerFields.style.display = 'none';
                coachKeyDiv.style.display = 'block';
                jerseyInput.disabled = true;
                positionSelect.disabled = true;
                ageInput.disabled = true;
                phoneInput.disabled = true;
            } else {
                playerFields.style.display = 'block';
                coachKeyDiv.style.display = 'none';
                jerseyInput.disabled = false;
                positionSelect.disabled = false;
                ageInput.disabled = false;
                phoneInput.disabled = false;
            }
        }

        roleSelect.addEventListener('change', updateForm);
        updateForm();

        // Validación de contraseña en tiempo real
        const passwordInput = document.querySelector('input[name="password"]');
        if (passwordInput) {
            passwordInput.addEventListener('input', function() {
                if (this.value.length > 0 && this.value.length < 6) {
                    this.style.borderColor = '#EF4444';
                } else if (this.value.length >= 6) {
                    this.style.borderColor = '#22C55E';
                } else {
                    this.style.borderColor = '#E5E7EB';
                }
            });
        }
    </script>
</body>
</html>