<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anuncios | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #F3F4F6;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
        .card-announcement {
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            border: 1px solid #E5E7EB;
        }
        .card-announcement:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(30, 58, 138, 0.15);
        }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
            z-index: 1100;
        }
        .modal.active {
            display: flex;
        }
        .modal-content {
            background: #FFFFFF;
            border-radius: 20px;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from { transform: translateY(-50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .modal-header button:hover {
            transform: rotate(90deg);
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-bold text-[#1E3A8A]">📢 Anuncios</h1>
                <p class="text-gray-500 mt-1">Mantén informado a todo el equipo</p>
            </div>
            <% if (user && user.role === 'coach') { %>
                <button onclick="openAnnouncementModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-5 py-2.5 rounded-xl transition-all duration-300 flex items-center gap-2 shadow-md hover:shadow-lg transform hover:-translate-y-0.5 font-semibold">
                    <span class="text-lg">➕</span> Crear Anuncio
                </button>
            <% } %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% if (typeof announcements !== 'undefined' && announcements && announcements.length > 0) { %>
                <% announcements.forEach(a => { %>
                    <div class="card-announcement p-6 flex flex-col justify-between">
                        <div>
                            <div class="flex justify-between items-start gap-4">
                                <h3 class="text-xl font-bold text-gray-900 break-words flex-1"><%= a.title %></h3>
                                <% if (user && user.role === 'coach') { %>
                                    <a href="/coach/announcements/<%= a.id %>/delete" class="text-red-500 hover:text-red-700 text-sm font-semibold transition-colors shrink-0" onclick="return confirm('¿Estás seguro de que deseas eliminar este anuncio?')">🗑️ Eliminar</a>
                                <% } %>
                            </div>
                            <p class="text-gray-600 mt-3 whitespace-pre-line"><%= a.content %></p>
                        </div>
                        
                        <div class="mt-6 flex justify-between items-center pt-4 border-t border-gray-100">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 bg-[#1E3A8A] rounded-full flex items-center justify-center text-white font-bold text-sm shadow-inner">
                                    <%= a.author_name ? a.author_name.charAt(0).toUpperCase() : 'A' %>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-gray-800"><%= a.author_name || 'Administrador' %></p>
                                    <p class="text-xs text-gray-400"><%= new Date(a.created_at).toLocaleString('es-CO', { dateStyle: 'medium', timeStyle: 'short' }) %></p>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-full">
                    <div class="card-announcement p-12 text-center">
                        <div class="text-5xl mb-4">📢</div>
                        <h3 class="text-2xl font-bold text-gray-600 mb-2">No hay anuncios</h3>
                        <p class="text-gray-400 max-w-sm mx-auto">No se han publicado comunicados recientes en la academia.</p>
                        <% if (user && user.role === 'coach') { %>
                            <button onclick="openAnnouncementModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-xl mt-4 transition shadow-md font-semibold">
                                ➕ Crear Anuncio
                            </button>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>

        <div class="mt-8 text-center">
            <a href="<%= user && user.role === 'coach' ? '/coach/dashboard' : '/player/dashboard' %>" class="bg-gray-600 hover:bg-gray-700 text-white px-6 py-2.5 rounded-xl transition inline-block shadow-md font-semibold">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <% if (user && user.role === 'coach') { %>
        <div id="announcementModal" class="modal">
            <div class="modal-content shadow-2xl">
                <div class="bg-[#1E3A8A] text-white padding p-5 rounded-t-[20px] flex justify-between items-center">
                    <h3 class="text-xl font-bold flex items-center gap-2">✏️ Crear Anuncio</h3>
                    <button onclick="closeAnnouncementModal()" class="text-3xl font-light leading-none transition-transform duration-200">&times;</button>
                </div>
                <form method="POST" action="/coach/announcements" class="p-6">
                    <div class="mb-4">
                        <label class="block text-sm font-semibold text-gray-800 mb-1.5">📌 Título</label>
                        <input type="text" name="title" class="w-full padding p-3 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] focus:ring-4 focus:ring-blue-100 transition text-sm text-gray-900" placeholder="Ej: Ajuste de horario entrenamiento" required>
                    </div>
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-gray-800 mb-1.5">📝 Contenido</label>
                        <textarea name="content" class="w-full padding p-3 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] focus:ring-4 focus:ring-blue-100 transition text-sm text-gray-900" rows="5" placeholder="Escribe las novedades aquí..." required></textarea>
                    </div>
                    <button type="submit" class="w-full bg-[#1E3A8A] hover:bg-[#172554] text-white py-3 rounded-xl font-semibold transition shadow-md hover:shadow-lg">📤 Publicar Anuncio</button>
                    <button type="button" onclick="closeAnnouncementModal()" class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 py-3 rounded-xl font-semibold mt-2 transition">❌ Cancelar</button>
                </form>
            </div>
        </div>
    <% } %>

    <%- include('../partials/footer') %>

    <script>
        const modal = document.getElementById('announcementModal');

        function openAnnouncementModal() {
            if (modal) modal.classList.add('active');
        }
        
        function closeAnnouncementModal() {
            if (modal) {
                modal.classList.remove('active');
                modal.querySelector('form')?.reset();
            }
        }
        
        window.onclick = function(event) {
            if (event.target === modal) {
                closeAnnouncementModal();
            }
        }
        
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape' && modal && modal.classList.contains('active')) {
                closeAnnouncementModal();
            }
        });
    </script>
</body>
</html>