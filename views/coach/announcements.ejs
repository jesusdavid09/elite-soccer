<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anuncios | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #F3F4F6;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
        .card-announcement {
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            border: 1px solid #E5E7EB;
        }
        .card-announcement:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(30, 58, 138, 0.15);
        }
        .btn-primary-custom {
            background: #1E3A8A;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.6rem 1.5rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-primary-custom:hover {
            background: #172554;
            transform: scale(1.05);
        }
        .btn-gray-custom {
            background: #4B5563;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.6rem 1.5rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-gray-custom:hover {
            background: #374151;
        }
        .btn-volver {
            background: #1E3A8A;
            color: #FFFFFF;
            transition: all 0.3s ease;
        }
        .btn-volver:hover {
            background: #172554;
        }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
            z-index: 1100;
        }
        .modal.active {
            display: flex;
        }
        .modal-content {
            background: #FFFFFF;
            border-radius: 20px;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from { transform: translateY(-50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .modal-header {
            background: #1E3A8A;
            color: #FFFFFF;
            padding: 1.25rem 1.5rem;
            border-radius: 20px 20px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-header button {
            background: none;
            border: none;
            color: #FFFFFF;
            font-size: 2rem;
            cursor: pointer;
            transition: transform 0.3s;
            line-height: 1;
        }
        .modal-header button:hover {
            transform: rotate(90deg);
        }
        .modal-body {
            padding: 1.5rem;
        }
        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: #111827;
            font-size: 0.9rem;
        }
        .form-input, .form-textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid #E5E7EB;
            border-radius: 12px;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            color: #111827;
        }
        .form-input:focus, .form-textarea:focus {
            outline: none;
            border-color: #1E3A8A;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }
        .alert-success {
            background: #D1FAE5;
            color: #065F46;
            padding: 0.75rem 1rem;
            border-radius: 12px;
            margin-bottom: 1rem;
            border: 1px solid #A7F3D0;
            text-align: center;
        }
        .alert-error {
            background: #FEE2E2;
            color: #991B1B;
            padding: 0.75rem 1rem;
            border-radius: 12px;
            margin-bottom: 1rem;
            border: 1px solid #FECACA;
            text-align: center;
        }
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
        }
        .empty-state .icon {
            font-size: 4rem;
            margin-bottom: 1rem;
        }
        .author-avatar {
            width: 32px;
            height: 32px;
            background: #1E3A8A;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #FFFFFF;
            font-weight: 700;
            font-size: 0.875rem;
            flex-shrink: 0;
        }
        .text-azul-rey {
            color: #1E3A8A;
        }
        .bg-azul-rey {
            background: #1E3A8A;
        }
        .bg-azul-rey:hover {
            background: #172554;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold" style="color: #1E3A8A;">📢 Anuncios</h1>
                <p class="text-gray-500 mt-1">Mantén informado a todo el equipo</p>
            </div>
            <button onclick="openAnnouncementModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-4 py-2 rounded-lg transition flex items-center gap-2 shadow-md mt-4 md:mt-0">
                <span class="text-lg">➕</span> Crear Anuncio
            </button>
        </div>

        <!-- Mensajes Flash -->
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert-success">✅ <%= success %></div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert-error">⚠️ <%= error %></div>
        <% } %>

        <!-- Lista de Anuncios -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% if (announcements && announcements.length > 0) { %>
                <% announcements.forEach(a => { %>
                    <div class="card-announcement p-6">
                        <h3 class="text-xl font-bold" style="color: #111827;"><%= a.title %></h3>
                        <p class="text-gray-600 mt-2"><%= a.content %></p>
                        <div class="mt-4 pt-4 border-t border-gray-200 flex justify-between items-center">
                            <div class="flex items-center gap-2">
                                <div class="author-avatar">
                                    <%= a.author_name ? a.author_name.charAt(0).toUpperCase() : 'A' %>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold" style="color: #111827;"><%= a.author_name || 'Administrador' %></p>
                                    <p class="text-xs text-gray-400"><%= new Date(a.created_at).toLocaleString() %></p>
                                </div>
                            </div>
                            <a href="/coach/announcements/<%= a.id %>/delete" class="text-red-500 hover:text-red-700 text-sm font-semibold transition" onclick="return confirm('¿Eliminar este anuncio?')">🗑️ Eliminar</a>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-full">
                    <div class="card-announcement p-12 empty-state">
                        <div class="icon">📢</div>
                        <h3 class="text-2xl font-bold text-gray-600 mb-2">No hay anuncios</h3>
                        <p class="text-gray-400">Comienza creando tu primer anuncio</p>
                        <button onclick="openAnnouncementModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg mt-4 transition shadow-md">
                            ➕ Crear Anuncio
                        </button>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- Volver -->
        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="btn-volver px-6 py-2 rounded-lg transition inline-block shadow-md">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <!-- ===== MODAL ANUNCIOS ===== -->
    <div id="announcementModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="text-xl font-bold">✏️ Crear Anuncio</h3>
                <button onclick="closeAnnouncementModal()">&times;</button>
            </div>
            <form method="POST" action="/coach/announcements" class="modal-body">
                <div class="mb-4">
                    <label class="form-label">📌 Título</label>
                    <input type="text" name="title" class="form-input" placeholder="Ej: Entrenamiento especial" required>
                </div>
                <div class="mb-4">
                    <label class="form-label">📝 Contenido</label>
                    <textarea name="content" class="form-textarea" rows="5" placeholder="Escribe el contenido del anuncio..." required></textarea>
                </div>
                <button type="submit" class="btn-primary-custom w-full">📤 Publicar Anuncio</button>
                <button type="button" onclick="closeAnnouncementModal()" class="btn-gray-custom w-full mt-2">❌ Cancelar</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        function openAnnouncementModal() {
            document.getElementById('announcementModal').classList.add('active');
        }
        
        function closeAnnouncementModal() {
            document.getElementById('announcementModal').classList.remove('active');
        }
        
        // Cerrar modal al hacer clic fuera
        window.onclick = function(event) {
            var modal = document.getElementById('announcementModal');
            if (event.target === modal) {
                closeAnnouncementModal();
            }
        }
        
        // Cerrar con tecla ESC
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                var modal = document.getElementById('announcementModal');
                if (modal.classList.contains('active')) {
                    closeAnnouncementModal();
                }
            }
        });
    </script>
</body>
</html>