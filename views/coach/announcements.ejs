<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anuncios | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-[#1E3A8A]">📢 Anuncios</h1>
                <p class="text-gray-500 mt-1">Mantén informado a todo el equipo</p>
            </div>
            <button onclick="openAnnouncementModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-4 py-2 rounded-lg transition flex items-center gap-2">
                ➕ Crear Anuncio
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% if (announcements && announcements.length > 0) { %>
                <% announcements.forEach(a => { %>
                    <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-200">
                        <div class="p-6">
                            <h3 class="text-xl font-bold text-gray-800"><%= a.title %></h3>
                            <p class="text-gray-600 mt-2"><%= a.content %></p>
                            <div class="mt-4 flex justify-between items-center">
                                <div class="flex items-center gap-2">
                                    <div class="w-8 h-8 bg-[#1E3A8A] rounded-full flex items-center justify-center text-white font-bold text-sm">
                                        <%= a.author_name ? a.author_name.charAt(0).toUpperCase() : 'A' %>
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold"><%= a.author_name || 'Administrador' %></p>
                                        <p class="text-xs text-gray-400"><%= new Date(a.created_at).toLocaleString() %></p>
                                    </div>
                                </div>
                                <a href="/coach/announcements/<%= a.id %>/delete" class="text-red-500 hover:text-red-700 text-sm" onclick="return confirm('¿Eliminar?')">🗑️</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-full text-center py-12 bg-white rounded-xl shadow border border-gray-200">
                    <div class="text-6xl mb-4">📢</div>
                    <h3 class="text-xl font-bold mb-2">No hay anuncios</h3>
                    <p class="text-gray-500">Comienza creando tu primer anuncio</p>
                    <button onclick="openAnnouncementModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg mt-4 transition">➕ Crear</button>
                </div>
            <% } %>
        </div>

        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg transition inline-block">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <!-- ===== MODAL ANUNCIOS ===== -->
    <div id="announcementModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="text-xl font-bold">Crear Anuncio</h3>
                <button onclick="closeAnnouncementModal()">&times;</button>
            </div>
            <form method="POST" action="/coach/announcements" class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Título</label>
                    <input type="text" name="title" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Contenido</label>
                    <textarea name="content" class="form-textarea" rows="5" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-full">Publicar</button>
                <button type="button" onclick="closeAnnouncementModal()" class="btn btn-gray w-full mt-2">Cancelar</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <style>
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); align-items: center; justify-content: center; z-index: 1100; }
        .modal.active { display: flex; }
        .modal-content { background: white; border-radius: 20px; max-width: 500px; width: 90%; max-height: 90vh; overflow-y: auto; }
        .modal-header { background: #1E3A8A; color: white; padding: 1.25rem 1.5rem; border-radius: 20px 20px 0 0; display: flex; justify-content: space-between; align-items: center; }
        .modal-header button { background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer; }
        .modal-body { padding: 1.5rem; }
        .btn-primary { background: #1E3A8A; color: white; padding: 0.6rem 1.5rem; border-radius: 12px; border: none; cursor: pointer; transition: all 0.3s; font-weight: 600; }
        .btn-primary:hover { background: #172554; }
        .btn-gray { background: #4B5563; color: white; padding: 0.6rem 1.5rem; border-radius: 12px; border: none; cursor: pointer; transition: all 0.3s; font-weight: 600; }
        .btn-gray:hover { background: #374151; }
        .form-input, .form-textarea { width: 100%; padding: 0.75rem 1rem; border: 2px solid #E5E7EB; border-radius: 12px; transition: all 0.3s; font-family: 'Inter', sans-serif; font-size: 0.9rem; }
        .form-input:focus, .form-textarea:focus { outline: none; border-color: #1E3A8A; box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1); }
        .form-label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: #111827; font-size: 0.9rem; }
    </style>

    <script>
        function openAnnouncementModal() {
            document.getElementById('announcementModal').classList.add('active');
        }
        function closeAnnouncementModal() {
            document.getElementById('announcementModal').classList.remove('active');
        }
        window.onclick = function(event) {
            var modal = document.getElementById('announcementModal');
            if (event.target === modal) closeAnnouncementModal();
        }
    </script>
</body>
</html>