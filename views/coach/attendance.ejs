<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asistencia | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #F3F4F6;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
        .card-attendance {
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            border: 1px solid #E5E7EB;
        }
        .btn-primary-custom {
            background: #1E3A8A;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.5rem 1.5rem;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-primary-custom:hover {
            background: #172554;
            transform: scale(1.05);
        }
        .btn-success-custom {
            background: #22C55E;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.5rem 1.5rem;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-success-custom:hover {
            background: #16A34A;
            transform: scale(1.05);
        }
        .btn-gray-custom {
            background: #6B7280;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.5rem 1.5rem;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-gray-custom:hover {
            background: #4B5563;
        }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
            z-index: 1100;
        }
        .modal.active {
            display: flex;
        }
        .modal-content {
            background: #FFFFFF;
            border-radius: 20px;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from { transform: translateY(-50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .modal-header {
            background: #1E3A8A;
            color: #FFFFFF;
            padding: 1.25rem 1.5rem;
            border-radius: 20px 20px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-header button {
            background: none;
            border: none;
            color: #FFFFFF;
            font-size: 2rem;
            cursor: pointer;
            transition: transform 0.3s;
            line-height: 1;
        }
        .modal-header button:hover {
            transform: rotate(90deg);
        }
        .modal-body {
            padding: 1.5rem;
        }
        .form-label {
            display: block;
            margin-bottom: 0.25rem;
            font-weight: 600;
            color: #111827;
        }
        .form-input, .form-select, .form-textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid #E5E7EB;
            border-radius: 12px;
            transition: all 0.3s;
            font-size: 0.9rem;
            color: #111827;
        }
        .form-input:focus, .form-select:focus, .form-textarea:focus {
            outline: none;
            border-color: #1E3A8A;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }
        .player-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem;
            background: #F9FAFB;
            border-radius: 12px;
            transition: all 0.3s;
            border: 1px solid #E5E7EB;
        }
        .player-row:hover {
            background: #F3F4F6;
            transform: translateX(5px);
        }
        .attendance-buttons {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        .attendance-btn {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }
        .attendance-yes {
            background: #22C55E;
            color: #FFFFFF;
        }
        .attendance-yes:hover {
            background: #16A34A;
            transform: scale(1.05);
        }
        .attendance-maybe {
            background: #F59E0B;
            color: #FFFFFF;
        }
        .attendance-maybe:hover {
            background: #D97706;
            transform: scale(1.05);
        }
        .attendance-no {
            background: #EF4444;
            color: #FFFFFF;
        }
        .attendance-no:hover {
            background: #DC2626;
            transform: scale(1.05);
        }
        .status-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .status-confirmed {
            background: #22C55E;
            color: #FFFFFF;
        }
        .status-maybe {
            background: #F59E0B;
            color: #FFFFFF;
        }
        .status-absent {
            background: #EF4444;
            color: #FFFFFF;
        }
        .btn-volver {
            background: #1E3A8A;
            color: #FFFFFF;
            transition: all 0.3s ease;
        }
        .btn-volver:hover {
            background: #172554;
        }
        .text-azul-rey {
            color: #1E3A8A;
        }
        .bg-azul-rey {
            background: #1E3A8A;
        }
        .bg-azul-rey:hover {
            background: #172554;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Header -->
        <h1 class="text-3xl font-bold" style="color: #1E3A8A;">✅ Control de Asistencia</h1>
        <p class="text-gray-500 mb-8">Gestiona la asistencia de los jugadores</p>

        <!-- Selector de Evento -->
        <div class="card-attendance rounded-xl shadow-lg p-6 mb-8">
            <div class="flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-1">
                    <label class="form-label">📌 Seleccionar Evento</label>
                    <select id="eventSelect" class="form-select w-full">
                        <option value="">-- Seleccionar --</option>
                        <optgroup label="🏋️ Entrenamientos">
                            <% for (var i = 0; i < trainings.length; i++) { var t = trainings[i]; %>
                                <option value="training_<%= t.id %>"><%= t.title %> - <%= new Date(t.date).toLocaleDateString() %></option>
                            <% } %>
                        </optgroup>
                        <optgroup label="⚽ Partidos">
                            <% for (var i = 0; i < matches.length; i++) { var m = matches[i]; %>
                                <option value="match_<%= m.id %>">vs <%= m.opponent %> - <%= new Date(m.date).toLocaleDateString() %></option>
                            <% } %>
                        </optgroup>
                    </select>
                </div>
                <div>
                    <button id="loadEventBtn" class="btn-primary-custom">📂 Cargar Evento</button>
                </div>
            </div>
        </div>

        <!-- Pre-Evento (Confirmación) -->
        <div id="preEventSection" class="card-attendance rounded-xl shadow-lg p-6 mb-8" style="display: none;">
            <h2 class="text-xl font-bold mb-4" style="color: #1E3A8A;">📋 Confirmación de Asistencia</h2>
            <div id="preEventList" class="space-y-3"></div>
        </div>

        <!-- Post-Evento (Asistencia Real) -->
        <div id="postEventSection" class="card-attendance rounded-xl shadow-lg p-6" style="display: none;">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-4">
                <h2 class="text-xl font-bold" style="color: #1E3A8A;">✅ Asistencia Real</h2>
                <button id="saveAttendanceBtn" class="btn-success-custom">💾 Guardar Asistencia</button>
            </div>
            <div id="postEventList" class="space-y-3"></div>
        </div>

        <!-- Volver -->
        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="btn-volver px-6 py-2 rounded-lg transition inline-block shadow-md">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <!-- MODAL JUSTIFICACIÓN -->
    <div id="justificationModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="text-xl font-bold">📝 Justificación de Ausencia</h3>
                <button onclick="closeJustificationModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="mb-4">
                    <label class="form-label">Motivo</label>
                    <select id="reasonSelect" class="form-select w-full">
                        <option value="">Seleccionar motivo</option>
                        <option value="Estudio">📚 Estudio</option>
                        <option value="Trabajo">💼 Trabajo</option>
                        <option value="Enfermedad">🤒 Enfermedad</option>
                        <option value="Viaje">✈️ Viaje</option>
                        <option value="Compromiso familiar">👨‍👩‍👧 Compromiso familiar</option>
                        <option value="Otro">📝 Otro</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label">Explicación</label>
                    <textarea id="justificationText" class="form-textarea w-full" rows="3" placeholder="Escribe una explicación..."></textarea>
                </div>
                <div class="flex gap-3 mt-4">
                    <button onclick="closeJustificationModal()" class="btn-gray-custom flex-1">❌ Cancelar</button>
                    <button onclick="submitJustification()" class="btn-primary-custom flex-1">📤 Enviar</button>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        var currentEventType = null;
        var currentEventId = null;
        var currentPlayers = [];
        var pendingJustification = { playerId: null, status: null };

        // Cerrar modales al hacer clic fuera
        window.onclick = function(event) {
            if (event.target === document.getElementById('justificationModal')) {
                closeJustificationModal();
            }
        }

        // Cerrar con tecla ESC
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                if (document.getElementById('justificationModal').classList.contains('active')) {
                    closeJustificationModal();
                }
            }
        });

        // Cargar Evento
        document.getElementById('loadEventBtn').addEventListener('click', function() {
            var select = document.getElementById('eventSelect');
            var value = select.value;
            if (!value) { 
                alert('⚠️ Selecciona un evento primero'); 
                return; 
            }
            var parts = value.split('_');
            var type = parts[0];
            var id = parts[1];
            currentEventType = type;
            currentEventId = id;

            var preEventDiv = document.getElementById('preEventSection');
            var preEventList = document.getElementById('preEventList');
            preEventDiv.style.display = 'block';
            preEventList.innerHTML = '<p class="text-center text-gray-500 py-4">⏳ Cargando jugadores...</p>';

            fetch('/api/players/list')
                .then(function(response) { return response.json(); })
                .then(function(players) {
                    currentPlayers = players;
                    return fetch('/api/attendance/confirmations?type=' + type + '&id=' + id);
                })
                .then(function(response) { return response.json(); })
                .then(function(confirmations) {
                    var confirmMap = new Map();
                    confirmations.forEach(function(c) { confirmMap.set(c.player_id, c); });
                    var html = '';
                    if (currentPlayers.length === 0) {
                        html = '<p class="text-center text-gray-500 py-4">📭 No hay jugadores registrados</p>';
                    } else {
                        for (var i = 0; i < currentPlayers.length; i++) {
                            var player = currentPlayers[i];
                            var conf = confirmMap.get(player.id);
                            html += '<div class="player-row">';
                            html += '<div><div class="font-bold" style="color: #111827;">' + player.full_name + ' <span class="text-gray-500">#' + player.jersey_number + '</span></div>';
                            html += '<div class="text-sm text-gray-500">' + player.position + '</div></div>';
                            html += '<div>';
                            if (conf) {
                                var statusClass = conf.status === 'yes' ? 'status-confirmed' : (conf.status === 'maybe' ? 'status-maybe' : 'status-absent');
                                var statusText = conf.status === 'yes' ? '✅ Confirmado' : (conf.status === 'maybe' ? '🟡 Tal vez' : '❌ No asistirá');
                                html += '<div class="flex items-center gap-3 flex-wrap">';
                                html += '<span class="status-badge ' + statusClass + '">' + statusText + '</span>';
                                if (conf.justification) {
                                    html += '<span class="text-xs text-gray-500">📝 ' + conf.justification + '</span>';
                                }
                                html += '</div>';
                            } else {
                                html += '<div class="attendance-buttons">';
                                html += '<button onclick="confirmAttendance(' + player.id + ', \'yes\')" class="attendance-yes attendance-btn">✅ Sí</button>';
                                html += '<button onclick="confirmAttendance(' + player.id + ', \'maybe\')" class="attendance-maybe attendance-btn">🟡 Tal vez</button>';
                                html += '<button onclick="askJustification(' + player.id + ', \'no\')" class="attendance-no attendance-btn">❌ No</button>';
                                html += '</div>';
                            }
                            html += '</div></div>';
                        }
                    }
                    preEventList.innerHTML = html;
                })
                .catch(function(error) {
                    preEventList.innerHTML = '<p class="text-center text-red-500 py-4">❌ Error al cargar los datos</p>';
                    console.error(error);
                });
        });

        function confirmAttendance(playerId, status) {
            saveConfirmation(playerId, status, '');
            setTimeout(function() {
                document.getElementById('loadEventBtn').click();
            }, 300);
        }

        function askJustification(playerId, status) {
            pendingJustification = { playerId: playerId, status: status };
            document.getElementById('justificationModal').classList.add('active');
            document.getElementById('reasonSelect').value = '';
            document.getElementById('justificationText').value = '';
        }

        function submitJustification() {
            var reason = document.getElementById('reasonSelect').value;
            var explanation = document.getElementById('justificationText').value;
            
            if (!reason) {
                alert('⚠️ Por favor selecciona un motivo');
                return;
            }
            
            var justification = reason + (explanation ? ' - ' + explanation : '');
            saveConfirmation(pendingJustification.playerId, 'no', justification);
            closeJustificationModal();
            setTimeout(function() {
                document.getElementById('loadEventBtn').click();
            }, 300);
        }

        function saveConfirmation(playerId, status, justification) {
            fetch('/api/attendance/confirm', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: currentEventType,
                    id: currentEventId,
                    playerId: playerId,
                    status: status,
                    justification: justification
                })
            })
            .then(function(response) {
                if (!response.ok) {
                    throw new Error('Error al guardar');
                }
                return response.json();
            })
            .then(function(data) {
                if (!data.success) {
                    console.error('Error:', data.message);
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
            });
        }

        function closeJustificationModal() {
            document.getElementById('justificationModal').classList.remove('active');
            document.getElementById('reasonSelect').value = '';
            document.getElementById('justificationText').value = '';
            pendingJustification = { playerId: null, status: null };
        }

        document.getElementById('saveAttendanceBtn').addEventListener('click', function() {
            var attendanceData = {};
            var selects = document.querySelectorAll('.real-attendance-select');
            for (var i = 0; i < selects.length; i++) {
                var select = selects[i];
                attendanceData[select.dataset.playerId] = select.value;
            }
            
            if (Object.keys(attendanceData).length === 0) {
                alert('⚠️ No hay asistencias para guardar');
                return;
            }
            
            fetch('/api/attendance/real', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: currentEventType,
                    id: currentEventId,
                    attendance: attendanceData
                })
            })
            .then(function(response) { 
                if (!response.ok) {
                    throw new Error('Error al guardar');
                }
                return response.json(); 
            })
            .then(function(data) {
                if (data.success) {
                    alert('✅ Asistencia guardada correctamente');
                } else {
                    alert('❌ Error: ' + (data.message || 'No se pudo guardar'));
                }
            })
            .catch(function(error) {
                alert('❌ Error: ' + error.message);
            });
        });
    </script>
</body>
</html>