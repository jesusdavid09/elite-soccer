<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>
    
    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Banner -->
        <div class="relative rounded-2xl overflow-hidden mb-8">
            <div class="absolute inset-0 bg-gradient-to-r from-dark-blue to-sport-blue opacity-90"></div>
            <div class="relative z-10 p-8 text-white">
                <div class="flex items-center gap-4">
                    <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center text-3xl">⚽</div>
                    <div>
                        <h1 class="text-2xl font-bold">¡Bienvenido, <%= user.full_name %>!</h1>
                        <p class="text-white/80">"La excelencia no es un acto, sino un hábito"</p>
                    </div>
                </div>
                <div class="flex flex-wrap gap-4 mt-4">
                    <div class="bg-white/10 rounded-full px-4 py-1 text-sm">📅 <%= new Date().toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></div>
                    <div class="bg-white/10 rounded-full px-4 py-1 text-sm">👥 <%= stats.players %> jugadores</div>
                </div>
            </div>
        </div>

        <!-- Estadísticas -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white rounded-xl p-4 text-center shadow">
                <div class="text-3xl font-bold text-sport-blue"><%= stats.players %></div>
                <div class="text-sm text-gray-500">Jugadores</div>
            </div>
            <div class="bg-white rounded-xl p-4 text-center shadow">
                <div class="text-3xl font-bold text-sport-blue"><%= stats.trainings %></div>
                <div class="text-sm text-gray-500">Entrenamientos</div>
            </div>
            <div class="bg-white rounded-xl p-4 text-center shadow">
                <div class="text-3xl font-bold text-sport-blue"><%= stats.matches %></div>
                <div class="text-sm text-gray-500">Partidos</div>
            </div>
            <div class="bg-white rounded-xl p-4 text-center shadow">
                <div class="text-3xl font-bold text-sport-blue"><%= stats.announcements %></div>
                <div class="text-sm text-gray-500">Anuncios</div>
            </div>
        </div>

        <!-- Acciones rápidas -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-8">
            <a href="/coach/players" class="bg-blue-500 hover:bg-blue-600 text-white text-center py-2 rounded-lg">👥 Jugadores</a>
            <a href="/coach/trainings" class="bg-green-500 hover:bg-green-600 text-white text-center py-2 rounded-lg">🏋️ Entrenamientos</a>
            <a href="/coach/matches" class="bg-purple-500 hover:bg-purple-600 text-white text-center py-2 rounded-lg">⚽ Partidos</a>
            <a href="/coach/announcements" class="bg-orange-500 hover:bg-orange-600 text-white text-center py-2 rounded-lg">📢 Anuncios</a>
            <a href="/coach/attendance" class="bg-indigo-500 hover:bg-indigo-600 text-white text-center py-2 rounded-lg">✅ Asistencia</a>
        </div>

        <!-- Próximos eventos -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white rounded-xl p-6 shadow">
                <h3 class="text-lg font-bold mb-4">📅 Próximos Entrenamientos</h3>
                <% if (upcomingTrainings && upcomingTrainings.length > 0) { %>
                    <% upcomingTrainings.forEach(t => { %>
                        <div class="flex items-center gap-3 p-2 bg-gray-50 rounded-lg mb-2">
                            <span class="text-2xl">🏋️</span>
                            <div>
                                <div class="font-bold"><%= t.title %></div>
                                <div class="text-sm text-gray-500"><%= new Date(t.date).toLocaleDateString() %> - <%= t.time %></div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-gray-500 text-center py-4">No hay entrenamientos programados</p>
                <% } %>
            </div>
            <div class="bg-white rounded-xl p-6 shadow">
                <h3 class="text-lg font-bold mb-4">🏆 Próximos Partidos</h3>
                <% if (upcomingMatches && upcomingMatches.length > 0) { %>
                    <% upcomingMatches.forEach(m => { %>
                        <div class="flex items-center gap-3 p-2 bg-gray-50 rounded-lg mb-2">
                            <span class="text-2xl">⚽</span>
                            <div>
                                <div class="font-bold">vs <%= m.opponent %></div>
                                <div class="text-sm text-gray-500"><%= new Date(m.date).toLocaleDateString() %> - <%= m.time %></div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-gray-500 text-center py-4">No hay partidos programados</p>
                <% } %>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>