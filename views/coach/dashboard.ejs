<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Elite Soccer</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        @keyframes pulse-slow {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        .animate-pulse-slow { animation: pulse-slow 2s infinite; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Banner de Bienvenida -->
        <div class="bg-gradient-to-br from-[#1E3A8A] to-[#172554] rounded-2xl p-6 md:p-8 text-white mb-8 shadow-md">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
                <div class="flex items-center gap-4">
                    <div class="w-16 height-16 min-w-[64px] min-h-[64px] bg-white/20 rounded-full flex items-center justify-center text-3xl shadow-inner">
                        ⚽
                    </div>
                    <div>
                        <h1 class="text-xl md:text-2xl font-bold">¡Bienvenido, <%= user.full_name %>!</h1>
                        <p class="text-blue-300 text-sm italic mt-0.5">"La excelencia no es un acto, sino un hábito"</p>
                    </div>
                </div>
                
                <div class="flex flex-wrap gap-2.5">
                    <span class="bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 text-xs md:text-sm font-medium border border-white/5">
                        📅 <%= new Date().toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %>
                    </span>
                    <span class="bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 text-xs md:text-sm font-medium border border-white/5">
                        👥 <%= stats.players %> jugadores
                    </span>
                    <% if (pendingCount && pendingCount > 0) { %>
                        <span class="bg-rose-600 rounded-full px-4 py-1.5 text-xs md:text-sm font-bold flex items-center gap-1.5 shadow-sm animate-pulse-slow">
                            📋 <%= pendingCount %> solicitudes pendientes
                        </span>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Módulos de Estadísticas Rápidas -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
                <div class="text-3xl font-extrabold text-[#1E3A8A]"><%= stats.players %></div>
                <div class="text-xs md:text-sm font-medium text-gray-400 mt-1">Jugadores</div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
                <div class="text-3xl font-extrabold text-[#1E3A8A]"><%= stats.trainings %></div>
                <div class="text-xs md:text-sm font-medium text-gray-400 mt-1">Entrenamientos</div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
                <div class="text-3xl font-extrabold text-[#1E3A8A]"><%= stats.matches %></div>
                <div class="text-xs md:text-sm font-medium text-gray-400 mt-1">Partidos</div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
                <div class="text-3xl font-extrabold text-[#1E3A8A]"><%= stats.announcements %></div>
                <div class="text-xs md:text-sm font-medium text-gray-400 mt-1">Anuncios</div>
            </div>
        </div>

        <!-- Panel de Accesos Directos (Acciones) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
            <a href="/coach/players" class="bg-[#1E3A8A] hover:bg-[#172554] text-white text-center py-3.5 px-4 rounded-xl font-semibold shadow-sm transition-all duration-200 hover:scale-[1.02] active:scale-[0.99]">
                👥 Plantel de Jugadores
            </a>
            
            <a href="/coach/approve-players" class="bg-blue-600 hover:bg-blue-700 text-white py-3.5 px-4 rounded-xl font-semibold shadow-sm transition-all duration-200 hover:scale-[1.02] active:scale-[0.99] flex items-center justify-center gap-2">
                📋 Aprobar Solicitudes
                <% if (pendingCount && pendingCount > 0) { %>
                    <span class="bg-rose-500 text-white px-2 py-0.5 rounded-full text-xs font-bold animate-pulse-slow">
                        <%= pendingCount %>
                    </span>
                <% } %>
            </a>
            
            <a href="/coach/trainings" class="bg-[#1E3A8A] hover:bg-[#172554] text-white text-center py-3.5 px-4 rounded-xl font-semibold shadow-sm transition-all duration-200 hover:scale-[1.02] active:scale-[0.99]">
                🏋️ Planificar Entrenamientos
            </a>
            
            <a href="/coach/matches" class="bg-[#1E3A8A] hover:bg-[#172554] text-white text-center py-3.5 px-4 rounded-xl font-semibold shadow-sm transition-all duration-200 hover:scale-[1.02] active:scale-[0.99]">
                ⚽ Programar Partidos
            </a>
            
            <a href="/coach/announcements" class="bg-[#1E3A8A] hover:bg-[#172554] text-white text-center py-3.5 px-4 rounded-xl font-semibold shadow-sm transition-all duration-200 hover:scale-[1.02] active:scale-[0.99]">
                📢 Difundir Anuncios
            </a>
            
            <a href="/coach/attendance" class="bg-[#1E3A8A] hover:bg-[#172554] text-white text-center py-3.5 px-4 rounded-xl font-semibold shadow-sm transition-all duration-200 hover:scale-[1.02] active:scale-[0.99]">
                ✅ Control de Asistencia
            </a>
        </div>

        <!-- Bloque de Próximos Eventos -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Entrenamientos -->
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
                <h3 class="text-lg font-bold text-[#1E3A8A] mb-4 pb-2 border-b border-gray-100 flex items-center gap-2">
                    📅 Próximos Entrenamientos
                </h3>
                <div class="space-y-3">
                    <% if (upcomingTrainings && upcomingTrainings.length > 0) { %>
                        <% upcomingTrainings.forEach(t => { %>
                            <div class="flex items-center gap-3.5 p-3 bg-gray-50 rounded-xl border border-gray-200/60 hover:bg-gray-100 transition duration-150">
                                <span class="text-2xl bg-white w-11 h-11 rounded-lg flex items-center justify-center shadow-sm border border-gray-100">🏋️</span>
                                <div>
                                    <div class="font-bold text-gray-900 text-sm"><%= t.title %></div>
                                    <div class="text-xs text-gray-500 mt-0.5 font-medium">
                                        <%= new Date(t.date).toLocaleDateString('es-CO') %> — <span class="text-blue-700 font-semibold"><%= t.time %></span>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-gray-400 text-center py-6 text-sm">📭 No hay entrenamientos agendados</p>
                    <% } %>
                </div>
            </div>

            <!-- Partidos -->
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
                <h3 class="text-lg font-bold text-[#1E3A8A] mb-4 pb-2 border-b border-gray-100 flex items-center gap-2">
                    🏆 Próximos Partidos
                </h3>
                <div class="space-y-3">
                    <% if (upcomingMatches && upcomingMatches.length > 0) { %>
                        <% upcomingMatches.forEach(m => { %>
                            <div class="flex items-center gap-3.5 p-3 bg-gray-50 rounded-xl border border-gray-200/60 hover:bg-gray-100 transition duration-150">
                                <span class="text-2xl bg-white w-11 h-11 rounded-lg flex items-center justify-center shadow-sm border border-gray-100">⚽</span>
                                <div>
                                    <div class="font-bold text-gray-900 text-sm">vs <%= m.opponent %></div>
                                    <div class="text-xs text-gray-500 mt-0.5 font-medium">
                                        <%= new Date(m.date).toLocaleDateString('es-CO') %> — <span class="text-blue-700 font-semibold"><%= m.time %></span>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-gray-400 text-center py-6 text-sm">📭 No hay encuentros pactados</p>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>