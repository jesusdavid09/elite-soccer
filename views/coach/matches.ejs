<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Partidos | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-[#1E3A8A]">⚽ Gestión de Partidos</h1>
                <p class="text-gray-500 mt-1">Programa y organiza los partidos</p>
            </div>
            <button onclick="openModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-4 py-2 rounded-lg transition flex items-center gap-2">
                ➕ Agregar
            </button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">⚽</div>
                <div class="text-2xl font-bold text-[#1E3A8A]"><%= matches.length %></div>
                <div class="text-gray-500">Total</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">🏆</div>
                <div class="text-2xl font-bold text-[#1E3A8A]"><%= matches.filter(function(m) { return m.result_home !== null; }).length %></div>
                <div class="text-gray-500">Jugados</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">📅</div>
                <div class="text-2xl font-bold text-[#1E3A8A]"><%= matches.filter(function(m) { return new Date(m.date) >= new Date(); }).length %></div>
                <div class="text-gray-500">Próximos</div>
            </div>
        </div>

        <!-- Tabla -->
        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>Rival</th>
                        <th>Competición</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Lugar</th>
                        <th>Resultado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (matches && matches.length > 0) { %>
                        <% for (var i = 0; i < matches.length; i++) { var m = matches[i]; %>
                            <tr>
                                <td class="font-semibold"><%= m.home_team ? '🏠 ' : '✈️ ' %><%= m.opponent %></td>
                                <td><%= m.competition %></td>
                                <td><%= new Date(m.date).toLocaleDateString() %></td>
                                <td><%= m.time %></td>
                                <td><%= m.location %></td>
                                <td>
                                    <% if (m.result_home !== null && m.result_away !== null) { %>
                                        <span class="font-bold text-green-600"><%= m.result_home %> - <%= m.result_away %></span>
                                    <% } else { %>
                                        <span class="text-gray-400">-</span>
                                    <% } %>
                                </td>
                                <td class="flex gap-2">
                                    <button onclick="editMatch('<%= m.id %>')" class="text-yellow-500 hover:text-yellow-700">✏️</button>
                                    <a href="/coach/matches/<%= m.id %>/delete" class="text-red-500 hover:text-red-700" onclick="return confirm('¿Eliminar?')">🗑️</a>
                                </td>
                            </tr>
                        <% } %>
                    <% } else { %>
                        <tr><td colspan="7" class="text-center py-8 text-gray-500">No hay partidos</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg transition inline-block">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <!-- Modal -->
    <div id="modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modalTitle" class="text-xl font-bold">Agregar Partido</h3>
                <button onclick="closeModal()">&times;</button>
            </div>
            <form id="matchForm" method="POST" action="/coach/matches" class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Rival</label>
                    <input type="text" name="opponent" id="opponent" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Competición</label>
                    <input type="text" name="competition" id="competition" class="form-input" required>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div class="mb-3">
                        <label class="form-label">Fecha</label>
                        <input type="date" name="date" id="date" class="form-input" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hora</label>
                        <input type="time" name="time" id="time" class="form-input" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Lugar</label>
                    <input type="text" name="location" id="location" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="flex items-center gap-2">
                        <input type="checkbox" name="home_team" id="home_team" class="mr-2">
                        Jugamos de local
                    </label>
                </div>
                <button type="submit" class="btn btn-primary w-full">Guardar</button>
                <button type="button" onclick="closeModal()" class="btn btn-gray w-full mt-2">Cancelar</button>
            </form>
        </div>
    </div>

    <script>
        function openModal() {
            document.getElementById('modal').classList.add('active');
            document.getElementById('modalTitle').textContent = 'Agregar Partido';
            document.getElementById('matchForm').action = '/coach/matches';
            document.getElementById('matchForm').reset();
        }
        function closeModal() {
            document.getElementById('modal').classList.remove('active');
        }
        function editMatch(id) {
            fetch('/coach/matches/api/' + id)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    document.getElementById('modalTitle').textContent = 'Editar Partido';
                    document.getElementById('matchForm').action = '/coach/matches/' + id;
                    document.getElementById('opponent').value = data.opponent;
                    document.getElementById('competition').value = data.competition;
                    document.getElementById('date').value = data.date.split('T')[0];
                    document.getElementById('time').value = data.time;
                    document.getElementById('location').value = data.location;
                    document.getElementById('home_team').checked = data.home_team;
                    document.getElementById('modal').classList.add('active');
                });
        }
        window.onclick = function(event) {
            if (event.target === document.getElementById('modal')) closeModal();
        }
    </script>
</body>
</html>