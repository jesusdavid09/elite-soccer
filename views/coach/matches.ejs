<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Partidos | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            align-items: center; justify-content: center;
            z-index: 1100;
        }
        .modal.active { display: flex; }
        .modal-content { animation: slideIn 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
        @keyframes slideIn {
            from { transform: translateY(-30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-bold text-[#1E3A8A]">⚽ Gestión de Partidos</h1>
                <p class="text-gray-500 mt-1">Programa, edita y organiza el calendario de encuentros</p>
            </div>
            <button onclick="openMatchModal()" class="w-full sm:w-auto bg-[#1E3A8A] hover:bg-[#172554] text-white font-bold px-5 py-2.5 rounded-xl transition flex items-center justify-center gap-2 shadow-sm active:scale-[0.98]">
                <span>➕</span> Agregar Partido
            </button>
        </div>

        <!-- Indicadores / Estadísticas -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 text-center transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
                <div class="text-2xl mb-1">⚽</div>
                <div class="text-3xl font-extrabold text-[#1E3A8A]"><%= matches.length %></div>
                <div class="text-xs md:text-sm font-medium text-gray-400 mt-0.5">Total Partidos</div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 text-center transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
                <div class="text-2xl mb-1">🏆</div>
                <div class="text-3xl font-extrabold text-[#1E3A8A]"><%= matches.filter(function(m) { return m.result_home !== null; }).length %></div>
                <div class="text-xs md:text-sm font-medium text-gray-400 mt-0.5">Disputados</div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 text-center transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
                <div class="text-2xl mb-1">📅</div>
                <div class="text-3xl font-extrabold text-[#1E3A8A]"><%= matches.filter(function(m) { return new Date(m.date) >= new Date(); }).length %></div>
                <div class="text-xs md:text-sm font-medium text-gray-400 mt-0.5">Próximos</div>
            </div>
        </div>

        <!-- Tabla de Contenido -->
        <div class="overflow-x-auto bg-white rounded-2xl border border-gray-200 shadow-sm">
            <table class="w-full border-collapse text-left text-sm whitespace-nowrap">
                <thead>
                    <tr class="bg-[#1E3A8A] text-white font-semibold">
                        <th class="px-5 py-3.5">Rival</th>
                        <th class="px-5 py-3.5">Competición</th>
                        <th class="px-5 py-3.5">Fecha</th>
                        <th class="px-5 py-3.5">Hora</th>
                        <th class="px-5 py-3.5">Lugar</th>
                        <th class="px-5 py-3.5">Resultado</th>
                        <th class="px-5 py-3.5 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 text-gray-900 font-medium">
                    <% if (matches && matches.length > 0) { %>
                        <% for (var i = 0; i < matches.length; i++) { var m = matches[i]; %>
                            <tr class="hover:bg-gray-50/80 transition duration-150">
                                <td class="px-5 py-4 font-bold text-gray-900">
                                    <%= m.home_team ? '🏠 ' : '✈️ ' %><%= m.opponent %>
                                </td>
                                <td class="px-5 py-4 text-gray-600"><%= m.competition %></td>
                                <td class="px-5 py-4 text-gray-600"><%= new Date(m.date).toLocaleDateString('es-CO') %></td>
                                <td class="px-5 py-4 text-gray-500"><%= m.time %></td>
                                <td class="px-5 py-4 text-gray-600 max-w-xs truncate" title="<%= m.location %>"><%= m.location %></td>
                                <td class="px-5 py-4">
                                    <% if (m.result_home !== null && m.result_away !== null) { %>
                                        <span class="text-emerald-600 font-black text-base"><%= m.result_home %> - <%= m.result_away %></span>
                                    <% } else { %>
                                        <span class="text-gray-300 font-bold">—</span>
                                    <% } %>
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <div class="flex items-center justify-center gap-3">
                                        <button onclick="editMatch('<%= m.id %>')" class="text-amber-500 hover:text-amber-600 transition hover:scale-110" title="Editar partido">
                                            ✏️
                                        </button>
                                        <a href="/coach/matches/<%= m.id %>/delete" class="text-rose-500 hover:text-rose-600 transition hover:scale-110" onclick="return confirm('¿Estás seguro de que deseas eliminar este partido programado?')" title="Eliminar partido">
                                            🗑️
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center py-12 text-gray-400">
                                <span class="text-4xl block mb-2">⚽</span>
                                <p class="text-sm">No hay registros de partidos en la base de datos.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Botón de Retorno -->
        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="bg-gray-600 hover:bg-gray-700 text-white font-semibold px-6 py-2.5 rounded-xl transition inline-block shadow-sm">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <!-- ===== MODAL DINÁMICO DE PARTIDOS ===== -->
    <div id="matchModal" class="modal">
        <div class="modal-content bg-white rounded-2xl max-w-md w-11/12 overflow-hidden shadow-2xl">
            <div class="bg-[#1E3A8A] text-white px-6 py-4 flex justify-between items-center">
                <h3 id="matchModalTitle" class="text-lg font-bold">➕ Agregar Partido</h3>
                <button onclick="closeMatchModal()" class="text-3xl font-light leading-none hover:rotate-90 transition duration-200">&times;</button>
            </div>
            <form id="matchForm" method="POST" action="/coach/matches" class="p-6">
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-900 mb-1.5">🏟️ Club Rival</label>
                    <input type="text" name="opponent" id="matchOpponent" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] focus:ring-3 focus:ring-blue-500/10 text-sm font-medium text-gray-800" placeholder="Ej: Real Madrid" required>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-900 mb-1.5">🏆 Torneo / Competición</label>
                    <input type="text" name="competition" id="matchCompetition" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] focus:ring-3 focus:ring-blue-500/10 text-sm font-medium text-gray-800" placeholder="Ej: Torneo Nacional o Liga Local" required>
                </div>
                <div class="grid grid-cols-2 gap-3 mb-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-1.5">📅 Fecha</label>
                        <input type="date" name="date" id="matchDate" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] text-sm font-medium text-gray-800" required>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-1.5">🕐 Hora</label>
                        <input type="time" name="time" id="matchTime" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] text-sm font-medium text-gray-800" required>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-900 mb-1.5">📍 Complejo / Lugar</label>
                    <input type="text" name="location" id="matchLocation" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] focus:ring-3 focus:ring-blue-500/10 text-sm font-medium text-gray-800" placeholder="Ej: Sede Deportiva Norte" required>
                </div>
                <div class="mb-5">
                    <label class="inline-flex items-center gap-2 cursor-pointer select-none text-sm font-semibold text-gray-900">
                        <input type="checkbox" name="home_team" id="matchHomeTeam" class="w-4 h-4 accent-[#1E3A8A] rounded-md">
                        🏠 ¿Jugamos en condición de Local?
                    </label>
                </div>
                <div class="flex flex-col gap-2">
                    <button type="submit" class="w-full bg-[#1E3A8A] hover:bg-[#172554] text-white font-bold py-2.5 rounded-xl transition shadow-sm">💾 Guardar Partido</button>
                    <button type="button" onclick="closeMatchModal()" class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2.5 rounded-xl transition">❌ Cancelar</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        function openMatchModal() {
            document.getElementById('matchModal').classList.add('active');
            document.getElementById('matchModalTitle').textContent = '➕ Agregar Partido';
            document.getElementById('matchForm').action = '/coach/matches';
            document.getElementById('matchForm').reset();
            document.getElementById('matchHomeTeam').checked = false;
        }
        
        function closeMatchModal() {
            document.getElementById('matchModal').classList.remove('active');
        }
        
        function editMatch(id) {
            fetch('/coach/matches/api/' + id)
                .then(function(response) {
                    if (!response.ok) throw new Error('Error al extraer datos');
                    return response.json();
                })
                .then(function(data) {
                    document.getElementById('matchModalTitle').textContent = '✏️ Editar Partido';
                    document.getElementById('matchForm').action = '/coach/matches/' + id;
                    document.getElementById('matchOpponent').value = data.opponent || '';
                    document.getElementById('matchCompetition').value = data.competition || '';
                    if (data.date) {
                        document.getElementById('matchDate').value = data.date.split('T')[0];
                    }
                    document.getElementById('matchTime').value = data.time || '';
                    document.getElementById('matchLocation').value = data.location || '';
                    document.getElementById('matchHomeTeam').checked = data.home_team || false;
                    document.getElementById('matchModal').classList.add('active');
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('❌ Ocurrió un error al cargar la información del encuentro.');
                });
        }
        
        window.onclick = function(event) {
            var modal = document.getElementById('matchModal');
            if (event.target === modal) closeMatchModal();
        }
        
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                var modal = document.getElementById('matchModal');
                if (modal.classList.contains('active')) closeMatchModal();
            }
        });
    </script>
</body>
</html>