<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Partidos | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-dark-blue">⚽ Gestión de Partidos</h1>
                <p class="text-gray-500 mt-1">Programa y organiza los partidos del equipo</p>
            </div>
            <button onclick="openModal()" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg transition flex items-center gap-2">
                ➕ Agregar Partido
            </button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow p-6 text-center">
                <div class="text-3xl mb-2">⚽</div>
                <div class="text-2xl font-bold text-sport-blue"><%= matches.length %></div>
                <div class="text-gray-500">Total Partidos</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center">
                <div class="text-3xl mb-2">🏆</div>
                <div class="text-2xl font-bold text-sport-blue"><%= matches.filter(function(m) { return m.result_home !== null; }).length %></div>
                <div class="text-gray-500">Partidos Jugados</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center">
                <div class="text-3xl mb-2">📅</div>
                <div class="text-2xl font-bold text-sport-blue"><%= matches.filter(function(m) { return new Date(m.date) >= new Date(); }).length %></div>
                <div class="text-gray-500">Próximos Partidos</div>
            </div>
        </div>

        <!-- Tabla -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Rival</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Competición</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Hora</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Lugar</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Resultado</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (matches && matches.length > 0) { %>
                            <% for (var i = 0; i < matches.length; i++) { 
                                var m = matches[i];
                            %>
                                <tr class="border-t border-gray-200 hover:bg-gray-50 transition">
                                    <td class="px-6 py-4 font-semibold"><%= m.home_team ? '🏠 ' : '✈️ ' %><%= m.opponent %></td>
                                    <td class="px-6 py-4"><%= m.competition %></td>
                                    <td class="px-6 py-4"><%= new Date(m.date).toLocaleDateString() %></td>
                                    <td class="px-6 py-4"><%= m.time %></td>
                                    <td class="px-6 py-4"><%= m.location %></td>
                                    <td class="px-6 py-4">
                                        <% if (m.result_home !== null && m.result_away !== null) { %>
                                            <span class="font-bold text-green-600"><%= m.result_home %> - <%= m.result_away %></span>
                                        <% } else { %>
                                            <span class="text-gray-400">-</span>
                                        <% } %>
                                    </td>
                                    <td class="px-6 py-4 flex gap-2">
                                        <button onclick="editMatch('<%= m.id %>')" class="text-yellow-500 hover:text-yellow-700">✏️</button>
                                        <a href="/coach/matches/<%= m.id %>/delete" class="text-red-500 hover:text-red-700" onclick="return confirm('¿Eliminar este partido?')">🗑️</a>
                                    </td>
                                </tr>
                            <% } %>
                        <% } else { %>
                            <tr><td colspan="7" class="text-center py-8 text-gray-500">No hay partidos registrados</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="bg-gray-500 hover:bg-gray-600 text-white px-6 py-2 rounded-lg transition inline-block">← Volver al Dashboard</a>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <!-- Modal -->
    <div id="modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 w-full max-w-md">
            <div class="flex justify-between items-center mb-4">
                <h3 id="modalTitle" class="text-xl font-bold">Agregar Partido</h3>
                <button onclick="closeModal()" class="text-2xl text-gray-500 hover:text-gray-700">&times;</button>
            </div>
            <form id="matchForm" method="POST" action="/coach/matches">
                <div class="mb-3">
                    <label class="block text-sm font-medium mb-1">Rival</label>
                    <input type="text" name="opponent" id="opponent" class="w-full border border-gray-300 rounded-lg px-3 py-2" required>
                </div>
                <div class="mb-3">
                    <label class="block text-sm font-medium mb-1">Competición</label>
                    <input type="text" name="competition" id="competition" class="w-full border border-gray-300 rounded-lg px-3 py-2" required>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div class="mb-3">
                        <label class="block text-sm font-medium mb-1">Fecha</label>
                        <input type="date" name="date" id="date" class="w-full border border-gray-300 rounded-lg px-3 py-2" required>
                    </div>
                    <div class="mb-3">
                        <label class="block text-sm font-medium mb-1">Hora</label>
                        <input type="time" name="time" id="time" class="w-full border border-gray-300 rounded-lg px-3 py-2" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="block text-sm font-medium mb-1">Lugar</label>
                    <input type="text" name="location" id="location" class="w-full border border-gray-300 rounded-lg px-3 py-2" required>
                </div>
                <div class="mb-3">
                    <label class="flex items-center gap-2">
                        <input type="checkbox" name="home_team" id="home_team" class="mr-2">
                        Jugamos de local
                    </label>
                </div>
                <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white py-2 rounded-lg transition">Guardar</button>
                <button type="button" onclick="closeModal()" class="w-full mt-2 bg-gray-200 hover:bg-gray-300 py-2 rounded-lg transition">Cancelar</button>
            </form>
        </div>
    </div>

    <script>
        function openModal() {
            document.getElementById('modal').classList.remove('hidden');
            document.getElementById('modal').classList.add('flex');
            document.getElementById('modalTitle').textContent = 'Agregar Partido';
            document.getElementById('matchForm').action = '/coach/matches';
            document.getElementById('matchForm').reset();
        }

        function closeModal() {
            document.getElementById('modal').classList.add('hidden');
            document.getElementById('modal').classList.remove('flex');
        }

        function editMatch(id) {
            fetch('/coach/matches/api/' + id)
                .then(function(response) {
                    return response.json();
                })
                .then(function(data) {
                    document.getElementById('modalTitle').textContent = 'Editar Partido';
                    document.getElementById('matchForm').action = '/coach/matches/' + id;
                    document.getElementById('opponent').value = data.opponent;
                    document.getElementById('competition').value = data.competition;
                    document.getElementById('date').value = data.date.split('T')[0];
                    document.getElementById('time').value = data.time;
                    document.getElementById('location').value = data.location;
                    document.getElementById('home_team').checked = data.home_team;
                    document.getElementById('modal').classList.remove('hidden');
                    document.getElementById('modal').classList.add('flex');
                })
                .catch(function(error) {
                    console.error('Error al cargar partido:', error);
                    alert('Error al cargar los datos del partido');
                });
        }

        window.onclick = function(event) {
            var modal = document.getElementById('modal');
            if (event.target === modal) {
                closeModal();
            }
        }
    </script>
</body>
</html>