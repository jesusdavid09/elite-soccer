<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Partidos | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-[#1E3A8A]">⚽ Gestión de Partidos</h1>
                <p class="text-gray-500 mt-1">Programa y organiza los partidos</p>
            </div>
            <button onclick="openMatchModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-4 py-2 rounded-lg transition flex items-center gap-2">
                ➕ Agregar Partido
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">⚽</div>
                <div class="text-2xl font-bold text-[#1E3A8A]"><%= matches.length %></div>
                <div class="text-gray-500">Total</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">🏆</div>
                <div class="text-2xl font-bold text-[#1E3A8A]"><%= matches.filter(function(m) { return m.result_home !== null; }).length %></div>
                <div class="text-gray-500">Jugados</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">📅</div>
                <div class="text-2xl font-bold text-[#1E3A8A]"><%= matches.filter(function(m) { return new Date(m.date) >= new Date(); }).length %></div>
                <div class="text-gray-500">Próximos</div>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>Rival</th>
                        <th>Competición</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Lugar</th>
                        <th>Resultado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (matches && matches.length > 0) { %>
                        <% for (var i = 0; i < matches.length; i++) { var m = matches[i]; %>
                            <tr>
                                <td class="font-semibold"><%= m.home_team ? '🏠 ' : '✈️ ' %><%= m.opponent %></td>
                                <td><%= m.competition %></td>
                                <td><%= new Date(m.date).toLocaleDateString() %></td>
                                <td><%= m.time %></td>
                                <td><%= m.location %></td>
                                <td>
                                    <% if (m.result_home !== null && m.result_away !== null) { %>
                                        <span class="font-bold text-green-600"><%= m.result_home %> - <%= m.result_away %></span>
                                    <% } else { %>
                                        <span class="text-gray-400">-</span>
                                    <% } %>
                                </td>
                                <td class="flex gap-2">
                                    <button onclick="editMatch('<%= m.id %>')" class="text-yellow-500 hover:text-yellow-700">✏️</button>
                                    <a href="/coach/matches/<%= m.id %>/delete" class="text-red-500 hover:text-red-700" onclick="return confirm('¿Eliminar?')">🗑️</a>
                                </td>
                            </tr>
                        <% } %>
                    <% } else { %>
                        <tr><td colspan="7" class="text-center py-8 text-gray-500">No hay partidos</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg transition inline-block">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <!-- ===== MODAL PARTIDOS ===== -->
    <div id="matchModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="matchModalTitle" class="text-xl font-bold">Agregar Partido</h3>
                <button onclick="closeMatchModal()">&times;</button>
            </div>
            <form id="matchForm" method="POST" action="/coach/matches" class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Rival</label>
                    <input type="text" name="opponent" id="matchOpponent" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Competición</label>
                    <input type="text" name="competition" id="matchCompetition" class="form-input" required>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div class="mb-3">
                        <label class="form-label">Fecha</label>
                        <input type="date" name="date" id="matchDate" class="form-input" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hora</label>
                        <input type="time" name="time" id="matchTime" class="form-input" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Lugar</label>
                    <input type="text" name="location" id="matchLocation" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="flex items-center gap-2">
                        <input type="checkbox" name="home_team" id="matchHomeTeam" class="mr-2">
                        Jugamos de local
                    </label>
                </div>
                <button type="submit" class="btn btn-primary w-full">Guardar</button>
                <button type="button" onclick="closeMatchModal()" class="btn btn-gray w-full mt-2">Cancelar</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <style>
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); align-items: center; justify-content: center; z-index: 1100; }
        .modal.active { display: flex; }
        .modal-content { background: white; border-radius: 20px; max-width: 500px; width: 90%; max-height: 90vh; overflow-y: auto; }
        .modal-header { background: #1E3A8A; color: white; padding: 1.25rem 1.5rem; border-radius: 20px 20px 0 0; display: flex; justify-content: space-between; align-items: center; }
        .modal-header button { background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer; }
        .modal-body { padding: 1.5rem; }
        .btn-primary { background: #1E3A8A; color: white; padding: 0.6rem 1.5rem; border-radius: 12px; border: none; cursor: pointer; transition: all 0.3s; font-weight: 600; }
        .btn-primary:hover { background: #172554; }
        .btn-gray { background: #4B5563; color: white; padding: 0.6rem 1.5rem; border-radius: 12px; border: none; cursor: pointer; transition: all 0.3s; font-weight: 600; }
        .btn-gray:hover { background: #374151; }
        .form-input, .form-select { width: 100%; padding: 0.75rem 1rem; border: 2px solid #E5E7EB; border-radius: 12px; transition: all 0.3s; font-family: 'Inter', sans-serif; font-size: 0.9rem; }
        .form-input:focus, .form-select:focus { outline: none; border-color: #1E3A8A; box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1); }
        .form-label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: #111827; font-size: 0.9rem; }
    </style>

    <script>
        function openMatchModal() {
            document.getElementById('matchModal').classList.add('active');
            document.getElementById('matchModalTitle').textContent = 'Agregar Partido';
            document.getElementById('matchForm').action = '/coach/matches';
            document.getElementById('matchForm').reset();
        }
        function closeMatchModal() {
            document.getElementById('matchModal').classList.remove('active');
        }
        function editMatch(id) {
            fetch('/coach/matches/api/' + id)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    document.getElementById('matchModalTitle').textContent = 'Editar Partido';
                    document.getElementById('matchForm').action = '/coach/matches/' + id;
                    document.getElementById('matchOpponent').value = data.opponent;
                    document.getElementById('matchCompetition').value = data.competition;
                    document.getElementById('matchDate').value = data.date.split('T')[0];
                    document.getElementById('matchTime').value = data.time;
                    document.getElementById('matchLocation').value = data.location;
                    document.getElementById('matchHomeTeam').checked = data.home_team;
                    document.getElementById('matchModal').classList.add('active');
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('Error al cargar los datos');
                });
        }
        window.onclick = function(event) {
            var modal = document.getElementById('matchModal');
            if (event.target === modal) closeMatchModal();
        }
    </script>
</body>
</html>