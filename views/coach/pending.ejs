<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aprobaciones Pendientes | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #F3F4F6;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
        .card-pending {
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            border: 1px solid #E5E7EB;
        }
        .table-wrapper {
            overflow-x: auto;
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            border: 1px solid #E5E7EB;
        }
        .table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }
        .table thead {
            background: #1E3A8A;
            color: #FFFFFF;
        }
        .table thead th {
            padding: 0.75rem 1rem;
            text-align: left;
            font-weight: 600;
        }
        .table tbody td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #E5E7EB;
            color: #111827;
        }
        .table tbody tr:hover {
            background: #F9FAFB;
        }
        .btn-approve {
            background: #22C55E;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.3rem 1rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }
        .btn-approve:hover {
            background: #16A34A;
            transform: scale(1.05);
        }
        .btn-reject {
            background: #EF4444;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.3rem 1rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }
        .btn-reject:hover {
            background: #DC2626;
            transform: scale(1.05);
        }
        .btn-approve-all {
            background: #22C55E;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.5rem 1.5rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
        }
        .btn-approve-all:hover {
            background: #16A34A;
            transform: scale(1.05);
        }
        .btn-reject-all {
            background: #EF4444;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.5rem 1.5rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
        }
        .btn-reject-all:hover {
            background: #DC2626;
            transform: scale(1.05);
        }
        .btn-volver {
            background: #1E3A8A;
            color: #FFFFFF;
            transition: all 0.3s ease;
        }
        .btn-volver:hover {
            background: #172554;
        }
        .badge-pending {
            background: #FEF3C7;
            color: #92400E;
            padding: 0.25rem 1rem;
            border-radius: 9999px;
            font-size: 0.875rem;
            font-weight: 600;
        }
        .text-azul-rey {
            color: #1E3A8A;
        }
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
        }
        .empty-state .icon {
            font-size: 4rem;
            margin-bottom: 1rem;
        }
        .action-buttons {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold" style="color: #1E3A8A;">⏳ Solicitudes Pendientes</h1>
                <p class="text-gray-500 mt-1">Revisa y aprueba las solicitudes de nuevos jugadores</p>
            </div>
            <div class="badge-pending mt-4 md:mt-0">
                <%= users ? users.length : 0 %> solicitudes pendientes
            </div>
        </div>

        <!-- Tabla de Solicitudes -->
        <% if (users && users.length > 0) { %>
            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>📧 Email</th>
                            <th>👤 Nombre</th>
                            <th>📅 Fecha</th>
                            <th style="text-align: center;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(u => { %>
                            <tr>
                                <td><%= u.email %></td>
                                <td class="font-semibold" style="color: #111827;"><%= u.full_name %></td>
                                <td><%= new Date(u.created_at).toLocaleDateString() %></td>
                                <td style="text-align: center;">
                                    <div class="action-buttons" style="justify-content: center;">
                                        <a href="/coach/players/pending/<%= u.id %>/approve" class="btn-approve" onclick="return confirm('¿Aprobar a <%= u.full_name %>?')">✅ Aprobar</a>
                                        <a href="/coach/players/pending/<%= u.id %>/reject" class="btn-reject" onclick="return confirm('¿Rechazar a <%= u.full_name %>?')">❌ Rechazar</a>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Acciones masivas -->
            <div class="flex flex-wrap justify-end gap-3 mt-6">
                <button onclick="approveAll()" class="btn-approve-all">✅ Aprobar todas</button>
                <button onclick="rejectAll()" class="btn-reject-all">❌ Rechazar todas</button>
            </div>
        <% } else { %>
            <!-- Estado vacío -->
            <div class="card-pending rounded-xl shadow-lg p-12 text-center">
                <div class="empty-state">
                    <div class="icon">🎉</div>
                    <h3 class="text-2xl font-bold" style="color: #22C55E; margin-bottom: 0.5rem;">No hay solicitudes pendientes</h3>
                    <p class="text-gray-400">Todas las solicitudes han sido procesadas</p>
                    <a href="/coach/dashboard" class="inline-block mt-6 bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg transition shadow-md">
                        ← Volver al Dashboard
                    </a>
                </div>
            </div>
        <% } %>

        <!-- Volver -->
        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="btn-volver px-6 py-2 rounded-lg transition inline-block shadow-md">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script>
        function approveAll() {
            if (confirm('¿Aprobar TODAS las solicitudes pendientes?')) {
                fetch('/coach/players/pending/approve-all', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(function(response) {
                    if (response.ok) {
                        alert('✅ Todas las solicitudes han sido aprobadas');
                        location.reload();
                    } else {
                        alert('❌ Error al aprobar las solicitudes');
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('❌ Error de conexión');
                });
            }
        }
        
        function rejectAll() {
            if (confirm('¿Rechazar TODAS las solicitudes pendientes?')) {
                fetch('/coach/players/pending/reject-all', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(function(response) {
                    if (response.ok) {
                        alert('❌ Todas las solicitudes han sido rechazadas');
                        location.reload();
                    } else {
                        alert('❌ Error al rechazar las solicitudes');
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('❌ Error de conexión');
                });
            }
        }
    </script>
</body>
</html>