<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aprobaciones Pendientes | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-bold text-[#1E3A8A]">⏳ Solicitudes Pendientes</h1>
                <p class="text-gray-500 mt-1">Revisa y gestiona las solicitudes de acceso para nuevos jugadores</p>
            </div>
            <div class="inline-flex items-center bg-amber-100 text-amber-800 font-bold px-4 py-1.5 rounded-full text-sm border border-amber-200 shadow-sm">
                <%= users ? users.length : 0 %> solicitudes pendientes
            </div>
        </div>

        <% if (users && users.length > 0) { %>
            <div class="overflow-x-auto bg-white rounded-2xl border border-gray-200 shadow-sm">
                <table class="w-full border-collapse text-left text-sm whitespace-nowrap">
                    <thead>
                        <tr class="bg-[#1E3A8A] text-white font-semibold">
                            <th class="px-5 py-3.5">📧 Email</th>
                            <th class="px-5 py-3.5">👤 Nombre Completo</th>
                            <th class="px-5 py-3.5">📅 Fecha de Registro</th>
                            <th class="px-5 py-3.5 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 text-gray-900 font-medium">
                        <% users.forEach(u => { %>
                            <tr class="hover:bg-gray-50/80 transition duration-150">
                                <td class="px-5 py-4 text-gray-600"><%= u.email %></td>
                                <td class="px-5 py-4 font-bold text-gray-900"><%= u.full_name %></td>
                                <td class="px-5 py-4 text-gray-500"><%= new Date(u.created_at).toLocaleDateString('es-CO') %></td>
                                <td class="px-5 py-4 text-center">
                                    <div class="flex items-center justify-center gap-2">
                                        <a href="/coach/players/pending/<%= u.id %>/approve" class="bg-emerald-500 hover:bg-emerald-600 text-white font-semibold px-4 py-1.5 rounded-xl text-xs transition shadow-sm active:scale-95" onclick="return confirm('¿Aprobar el acceso de <%= u.full_name %> al sistema?')">
                                            ✅ Aprobar
                                        </a>
                                        <a href="/coach/players/pending/<%= u.id %>/reject" class="bg-rose-500 hover:bg-rose-600 text-white font-semibold px-4 py-1.5 rounded-xl text-xs transition shadow-sm active:scale-95" onclick="return confirm('¿Rechazar definitivamente la solicitud de <%= u.full_name %>?')">
                                            ❌ Rechazar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <div class="flex flex-col sm:flex-row justify-end gap-3 mt-6">
                <button onclick="approveAll()" class="w-full sm:w-auto bg-emerald-500 hover:bg-emerald-600 text-white font-bold px-5 py-2.5 rounded-xl text-sm transition shadow-sm active:scale-[0.98]">
                    ✅ Aprobar todas
                </button>
                <button onclick="rejectAll()" class="w-full sm:w-auto bg-rose-500 hover:bg-rose-600 text-white font-bold px-5 py-2.5 rounded-xl text-sm transition shadow-sm active:scale-[0.98]">
                    ❌ Rechazar todas
                </button>
            </div>
        <% } else { %>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-12 text-center max-w-2xl mx-auto">
                <div class="text-5xl mb-4">🎉</div>
                <h3 class="text-2xl font-bold text-emerald-600 mb-2">¡Al día! No hay solicitudes</h3>
                <p class="text-gray-400 text-sm max-w-sm mx-auto mb-6">Todos los nuevos registros de jugadores han sido procesados de manera exitosa.</p>
                <a href="/coach/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white font-semibold px-6 py-2.5 rounded-xl text-sm transition inline-block shadow-sm">
                    ← Volver al Dashboard
                </a>
            </div>
        <% } %>

        <% if (users && users.length > 0) { %>
            <div class="mt-8 text-center">
                <a href="/coach/dashboard" class="bg-gray-600 hover:bg-gray-700 text-white font-semibold px-6 py-2.5 rounded-xl text-sm transition inline-block shadow-sm">
                    ← Volver al Dashboard
                </a>
            </div>
        <% } %>
    </main>

    <%- include('../partials/footer') %>

    <script>
        function approveAll() {
            if (confirm('¿Estás seguro de que deseas APROBAR TODAS las solicitudes pendientes de forma masiva?')) {
                fetch('/coach/players/pending/approve-all', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(function(response) {
                    if (response.ok) {
                        alert('✅ Todas las solicitudes han sido aprobadas exitosamente.');
                        location.reload();
                    } else {
                        alert('❌ Ocurrió un error al intentar aprobar las solicitudes de forma masiva.');
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('❌ Error de red o conexión con el servidor.');
                });
            }
        }
        
        function rejectAll() {
            if (confirm('¿Estás seguro de que deseas RECHAZAR TODAS las solicitudes pendientes de forma masiva?')) {
                fetch('/coach/players/pending/reject-all', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(function(response) {
                    if (response.ok) {
                        alert('❌ Todas las solicitudes han sido rechazadas.');
                        location.reload();
                    } else {
                        alert('❌ Ocurrió un error al intentar denegar las solicitudes de forma masiva.');
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('❌ Error de red o conexión con el servidor.');
                });
            }
        }
    </script>
</body>
</html>