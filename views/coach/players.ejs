<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jugadores | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-[#1E3A8A]">👥 Plantilla de Jugadores</h1>
                <p class="text-gray-500 mt-1">Gestiona toda la información de tus jugadores</p>
            </div>
            <button onclick="openModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-4 py-2 rounded-lg transition flex items-center gap-2">
                ➕ Agregar Jugador
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">👥</div>
                <div class="text-2xl font-bold text-[#1E3A8A]"><%= players.length %></div>
                <div class="text-gray-500">Total Jugadores</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">⚡</div>
                <div class="text-2xl font-bold text-green-600">Activos</div>
                <div class="text-gray-500">En el club</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">📊</div>
                <div class="text-2xl font-bold text-orange-500">Posiciones</div>
                <div class="text-gray-500">Por definir</div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% if (players && players.length > 0) { %>
                <% for (var i = 0; i < players.length; i++) { var player = players[i]; %>
                    <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition hover:-translate-y-1 border border-gray-200">
                        <div class="p-6">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-24 h-24 bg-[#1E3A8A] rounded-full flex items-center justify-center text-3xl text-white shadow-lg">
                                    <%= player.jersey_number || '⚽' %>
                                </div>
                                <h3 class="text-xl font-bold mt-3"><%= player.full_name %></h3>
                                <p class="text-[#1E3A8A] font-semibold">#<%= player.jersey_number %></p>
                                <div class="flex gap-2 mt-2">
                                    <span class="bg-[#1E3A8A] text-white px-2 py-1 rounded-full text-xs"><%= player.position || 'Sin posición' %></span>
                                    <span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded-full text-xs"><%= player.age || '?' %> años</span>
                                </div>
                                <span class="mt-2 text-sm <%= player.active !== false ? 'text-green-600' : 'text-red-600' %>">
                                    <%= player.active !== false ? '✅ Activo' : '❌ Inactivo' %>
                                </span>
                            </div>
                            <div class="mt-4 pt-4 border-t border-gray-200 space-y-1 text-sm">
                                <div class="flex justify-between"><span class="text-gray-500">📧 Email</span><span><%= player.email %></span></div>
                                <div class="flex justify-between"><span class="text-gray-500">📱 Teléfono</span><span><%= player.phone || 'No registrado' %></span></div>
                                <div class="flex justify-between"><span class="text-gray-500">📅 Registro</span><span><%= new Date(player.created_at).toLocaleDateString() %></span></div>
                            </div>
                            <div class="mt-4 flex gap-2">
                                <button onclick="editPlayer('<%= player.id %>')" class="flex-1 bg-yellow-500 hover:bg-yellow-600 text-white py-2 rounded-lg text-sm transition">✏️ Editar</button>
                                <a href="/coach/players/<%= player.id %>/delete" class="flex-1 bg-red-500 hover:bg-red-600 text-white py-2 rounded-lg text-sm text-center transition" onclick="return confirm('¿Eliminar?')">🗑️ Eliminar</a>
                            </div>
                        </div>
                    </div>
                <% } %>
            <% } else { %>
                <div class="col-span-full text-center py-12 bg-white rounded-xl shadow border border-gray-200">
                    <div class="text-6xl mb-4">👥</div>
                    <h3 class="text-xl font-bold mb-2">No hay jugadores registrados</h3>
                    <p class="text-gray-500">Comienza agregando tu primer jugador</p>
                    <button onclick="openModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg mt-4 transition">➕ Agregar</button>
                </div>
            <% } %>
        </div>

        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg transition inline-block">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <!-- ===== MODAL ===== -->
    <div id="playerModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modalTitle" class="text-xl font-bold">Agregar Jugador</h3>
                <button onclick="closeModal()">&times;</button>
            </div>
            <form id="playerForm" method="POST" action="/coach/players" class="modal-body">
                <input type="hidden" id="playerId" name="id">
                <div class="mb-3">
                    <label class="form-label">ID del Usuario</label>
                    <input type="text" name="user_id" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Número de Camiseta</label>
                    <input type="number" name="jersey_number" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Posición</label>
                    <select name="position" class="form-select">
                        <option value="Portero">🧤 Portero</option>
                        <option value="Defensa Central">🛡️ Defensa Central</option>
                        <option value="Lateral Derecho">➡️ Lateral Derecho</option>
                        <option value="Lateral Izquierdo">⬅️ Lateral Izquierdo</option>
                        <option value="Mediocampista">🎯 Mediocampista</option>
                        <option value="Delantero">⚽ Delantero</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Edad</label>
                    <input type="number" name="age" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Teléfono</label>
                    <input type="text" name="phone" class="form-input">
                </div>
                <button type="submit" class="btn btn-primary w-full">Guardar</button>
                <button type="button" onclick="closeModal()" class="btn btn-gray w-full mt-2">Cancelar</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <style>
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
            z-index: 1100;
        }
        .modal.active {
            display: flex;
        }
        .modal-content {
            background: white;
            border-radius: 20px;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
        }
        .modal-header {
            background: #1E3A8A;
            color: white;
            padding: 1.25rem 1.5rem;
            border-radius: 20px 20px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-header button {
            background: none;
            border: none;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
        }
        .modal-body {
            padding: 1.5rem;
        }
        .btn-primary {
            background: #1E3A8A;
            color: white;
            padding: 0.6rem 1.5rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
        }
        .btn-primary:hover {
            background: #172554;
        }
        .btn-gray {
            background: #4B5563;
            color: white;
            padding: 0.6rem 1.5rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
        }
        .btn-gray:hover {
            background: #374151;
        }
        .form-input, .form-select {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid #E5E7EB;
            border-radius: 12px;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
        }
        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #1E3A8A;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }
        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: #111827;
            font-size: 0.9rem;
        }
    </style>

    <script>
        // ========== FUNCIONES DEL MODAL ==========
        function openModal() {
            var modal = document.getElementById('playerModal');
            modal.classList.add('active');
            document.getElementById('modalTitle').textContent = 'Agregar Jugador';
            document.getElementById('playerForm').action = '/coach/players';
            document.getElementById('playerId').value = '';
            document.getElementById('playerForm').reset();
        }

        function closeModal() {
            var modal = document.getElementById('playerModal');
            modal.classList.remove('active');
        }

        function editPlayer(id) {
            fetch('/coach/players/api/' + id)
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    document.getElementById('modalTitle').textContent = 'Editar Jugador';
                    document.getElementById('playerId').value = data.id;
                    document.querySelector('[name="user_id"]').value = data.user_id;
                    document.querySelector('[name="jersey_number"]').value = data.jersey_number;
                    document.querySelector('[name="position"]').value = data.position;
                    document.querySelector('[name="age"]').value = data.age;
                    document.querySelector('[name="phone"]').value = data.phone || '';
                    document.getElementById('playerForm').action = '/coach/players/' + data.id;
                    openModal();
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('Error al cargar los datos del jugador');
                });
        }

        // Cerrar modal al hacer clic fuera
        window.onclick = function(event) {
            var modal = document.getElementById('playerModal');
            if (event.target === modal) {
                closeModal();
            }
        }
    </script>
</body>
</html>