<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Entrenamientos | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #F3F4F6;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
        .card-training {
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            border: 1px solid #E5E7EB;
            transition: all 0.3s ease;
        }
        .card-training:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(30, 58, 138, 0.15);
        }
        .btn-primary-custom {
            background: #1E3A8A;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.6rem 1.5rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-primary-custom:hover {
            background: #172554;
            transform: scale(1.05);
        }
        .btn-gray-custom {
            background: #4B5563;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.6rem 1.5rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-gray-custom:hover {
            background: #374151;
        }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
            z-index: 1100;
        }
        .modal.active {
            display: flex;
        }
        .modal-content {
            background: #FFFFFF;
            border-radius: 20px;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from { transform: translateY(-50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .modal-header {
            background: #1E3A8A;
            color: #FFFFFF;
            padding: 1.25rem 1.5rem;
            border-radius: 20px 20px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-header button {
            background: none;
            border: none;
            color: #FFFFFF;
            font-size: 2rem;
            cursor: pointer;
            transition: transform 0.3s;
            line-height: 1;
        }
        .modal-header button:hover {
            transform: rotate(90deg);
        }
        .modal-body {
            padding: 1.5rem;
        }
        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: #111827;
            font-size: 0.9rem;
        }
        .form-input, .form-select, .form-textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid #E5E7EB;
            border-radius: 12px;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            color: #111827;
        }
        .form-input:focus, .form-select:focus, .form-textarea:focus {
            outline: none;
            border-color: #1E3A8A;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
        }
        .table-wrapper {
            overflow-x: auto;
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            border: 1px solid #E5E7EB;
        }
        .table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }
        .table thead {
            background: #1E3A8A;
            color: #FFFFFF;
        }
        .table thead th {
            padding: 0.75rem 1rem;
            text-align: left;
            font-weight: 600;
        }
        .table tbody td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #E5E7EB;
            color: #111827;
        }
        .table tbody tr:hover {
            background: #F9FAFB;
        }
        .btn-edit {
            color: #F59E0B;
            transition: all 0.3s ease;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1.1rem;
        }
        .btn-edit:hover {
            color: #D97706;
            transform: scale(1.1);
        }
        .btn-delete {
            color: #EF4444;
            transition: all 0.3s ease;
            font-size: 1.1rem;
            text-decoration: none;
        }
        .btn-delete:hover {
            color: #DC2626;
            transform: scale(1.1);
        }
        .btn-volver {
            background: #1E3A8A;
            color: #FFFFFF;
            transition: all 0.3s ease;
        }
        .btn-volver:hover {
            background: #172554;
        }
        .text-azul-rey {
            color: #1E3A8A;
        }
        .bg-azul-rey {
            background: #1E3A8A;
        }
        .bg-azul-rey:hover {
            background: #172554;
        }
        .stat-number {
            font-size: 2rem;
            font-weight: 700;
            color: #1E3A8A;
        }
        .stat-label {
            color: #6B7280;
            font-size: 0.9rem;
        }
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
        }
        .empty-state .icon {
            font-size: 4rem;
            margin-bottom: 1rem;
        }
        .action-buttons {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold" style="color: #1E3A8A;">🏋️ Gestión de Entrenamientos</h1>
                <p class="text-gray-500 mt-1">Organiza y planifica los entrenamientos</p>
            </div>
            <button onclick="openTrainingModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-4 py-2 rounded-lg transition flex items-center gap-2 shadow-md mt-4 md:mt-0">
                <span class="text-lg">➕</span> Agregar Entrenamiento
            </button>
        </div>

        <!-- Estadísticas -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
            <div class="card-training p-6 text-center">
                <div class="text-3xl mb-2">🏋️</div>
                <div class="stat-number"><%= trainings.length %></div>
                <div class="stat-label">Total Entrenamientos</div>
            </div>
            <div class="card-training p-6 text-center">
                <div class="text-3xl mb-2">📅</div>
                <div class="stat-number"><%= trainings.filter(function(t) { return new Date(t.date) >= new Date(); }).length %></div>
                <div class="stat-label">Próximos</div>
            </div>
            <div class="card-training p-6 text-center">
                <div class="text-3xl mb-2">✅</div>
                <div class="stat-number" style="color: #22C55E;">Asistencia</div>
                <div class="stat-label">Control</div>
            </div>
        </div>

        <!-- Tabla de Entrenamientos -->
        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>📌 Título</th>
                        <th>📝 Descripción</th>
                        <th>📅 Fecha</th>
                        <th>🕐 Hora</th>
                        <th>📍 Lugar</th>
                        <th style="text-align: center;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (trainings && trainings.length > 0) { %>
                        <% for (var i = 0; i < trainings.length; i++) { var t = trainings[i]; %>
                            <tr>
                                <td class="font-semibold" style="color: #111827;"><%= t.title %></td>
                                <td><%= t.description ? t.description.substring(0, 50) + (t.description.length > 50 ? '...' : '') : '-' %></td>
                                <td><%= new Date(t.date).toLocaleDateString() %></td>
                                <td><%= t.time %></td>
                                <td><%= t.location %></td>
                                <td style="text-align: center;">
                                    <div class="action-buttons" style="justify-content: center;">
                                        <button onclick="editTraining('<%= t.id %>')" class="btn-edit" title="Editar">✏️</button>
                                        <a href="/coach/trainings/<%= t.id %>/delete" class="btn-delete" onclick="return confirm('¿Eliminar este entrenamiento?')" title="Eliminar">🗑️</a>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center py-8" style="color: #6B7280;">
                                <span style="font-size: 3rem; display: block; margin-bottom: 0.5rem;">🏋️</span>
                                No hay entrenamientos registrados
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Volver -->
        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="btn-volver px-6 py-2 rounded-lg transition inline-block shadow-md">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <!-- ===== MODAL ENTRENAMIENTOS ===== -->
    <div id="trainingModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="trainingModalTitle" class="text-xl font-bold">➕ Agregar Entrenamiento</h3>
                <button onclick="closeTrainingModal()">&times;</button>
            </div>
            <form id="trainingForm" method="POST" action="/coach/trainings" class="modal-body">
                <div class="mb-4">
                    <label class="form-label">📌 Título</label>
                    <input type="text" name="title" id="trainingTitle" class="form-input" placeholder="Ej: Entrenamiento Técnico" required>
                </div>
                <div class="mb-4">
                    <label class="form-label">📝 Descripción</label>
                    <textarea name="description" id="trainingDescription" class="form-textarea" rows="3" placeholder="Describe el entrenamiento..."></textarea>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div class="mb-4">
                        <label class="form-label">📅 Fecha</label>
                        <input type="date" name="date" id="trainingDate" class="form-input" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">🕐 Hora</label>
                        <input type="time" name="time" id="trainingTime" class="form-input" required>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label">📍 Lugar</label>
                    <input type="text" name="location" id="trainingLocation" class="form-input" placeholder="Ej: Cancha Principal" required>
                </div>
                <div class="mb-4">
                    <label class="form-label">⏱️ Duración (minutos)</label>
                    <input type="number" name="duration" id="trainingDuration" class="form-input" placeholder="Ej: 90" min="1">
                </div>
                <button type="submit" class="btn-primary-custom w-full">💾 Guardar Entrenamiento</button>
                <button type="button" onclick="closeTrainingModal()" class="btn-gray-custom w-full mt-2">❌ Cancelar</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        function openTrainingModal() {
            document.getElementById('trainingModal').classList.add('active');
            document.getElementById('trainingModalTitle').textContent = '➕ Agregar Entrenamiento';
            document.getElementById('trainingForm').action = '/coach/trainings';
            document.getElementById('trainingForm').reset();
        }
        
        function closeTrainingModal() {
            document.getElementById('trainingModal').classList.remove('active');
        }
        
        function editTraining(id) {
            fetch('/coach/trainings/api/' + id)
                .then(function(response) {
                    if (!response.ok) {
                        throw new Error('Error al cargar los datos');
                    }
                    return response.json();
                })
                .then(function(data) {
                    document.getElementById('trainingModalTitle').textContent = '✏️ Editar Entrenamiento';
                    document.getElementById('trainingForm').action = '/coach/trainings/' + id;
                    document.getElementById('trainingTitle').value = data.title || '';
                    document.getElementById('trainingDescription').value = data.description || '';
                    if (data.date) {
                        document.getElementById('trainingDate').value = data.date.split('T')[0];
                    }
                    document.getElementById('trainingTime').value = data.time || '';
                    document.getElementById('trainingLocation').value = data.location || '';
                    document.getElementById('trainingDuration').value = data.duration || '';
                    document.getElementById('trainingModal').classList.add('active');
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('❌ Error al cargar los datos del entrenamiento: ' + error.message);
                });
        }
        
        // Cerrar modal al hacer clic fuera
        window.onclick = function(event) {
            var modal = document.getElementById('trainingModal');
            if (event.target === modal) {
                closeTrainingModal();
            }
        }
        
        // Cerrar con tecla ESC
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                var modal = document.getElementById('trainingModal');
                if (modal.classList.contains('active')) {
                    closeTrainingModal();
                }
            }
        });
    </script>
</body>
</html>