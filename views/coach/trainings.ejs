<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Entrenamientos | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-[#1E3A8A]">🏋️ Gestión de Entrenamientos</h1>
                <p class="text-gray-500 mt-1">Organiza y planifica los entrenamientos</p>
            </div>
            <button onclick="openTrainingModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-4 py-2 rounded-lg transition flex items-center gap-2">
                ➕ Agregar Entrenamiento
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">🏋️</div>
                <div class="text-2xl font-bold text-[#1E3A8A]"><%= trainings.length %></div>
                <div class="text-gray-500">Total</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">📅</div>
                <div class="text-2xl font-bold text-[#1E3A8A]"><%= trainings.filter(function(t) { return new Date(t.date) >= new Date(); }).length %></div>
                <div class="text-gray-500">Próximos</div>
            </div>
            <div class="bg-white rounded-xl shadow p-6 text-center border border-gray-200">
                <div class="text-3xl mb-2">✅</div>
                <div class="text-2xl font-bold text-green-600">Asistencia</div>
                <div class="text-gray-500">Control</div>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Descripción</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Lugar</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (trainings && trainings.length > 0) { %>
                        <% for (var i = 0; i < trainings.length; i++) { var t = trainings[i]; %>
                            <tr>
                                <td class="font-semibold"><%= t.title %></td>
                                <td><%= t.description ? t.description.substring(0, 50) + (t.description.length > 50 ? '...' : '') : '-' %></td>
                                <td><%= new Date(t.date).toLocaleDateString() %></td>
                                <td><%= t.time %></td>
                                <td><%= t.location %></td>
                                <td class="flex gap-2">
                                    <button onclick="editTraining('<%= t.id %>')" class="text-yellow-500 hover:text-yellow-700">✏️</button>
                                    <a href="/coach/trainings/<%= t.id %>/delete" class="text-red-500 hover:text-red-700" onclick="return confirm('¿Eliminar?')">🗑️</a>
                                </td>
                            </tr>
                        <% } %>
                    <% } else { %>
                        <tr><td colspan="6" class="text-center py-8 text-gray-500">No hay entrenamientos</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="mt-8 text-center">
            <a href="/coach/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg transition inline-block">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <!-- ===== MODAL ENTRENAMIENTOS ===== -->
    <div id="trainingModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="trainingModalTitle" class="text-xl font-bold">Agregar Entrenamiento</h3>
                <button onclick="closeTrainingModal()">&times;</button>
            </div>
            <form id="trainingForm" method="POST" action="/coach/trainings" class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Título</label>
                    <input type="text" name="title" id="trainingTitle" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Descripción</label>
                    <textarea name="description" id="trainingDescription" class="form-textarea" rows="3"></textarea>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div class="mb-3">
                        <label class="form-label">Fecha</label>
                        <input type="date" name="date" id="trainingDate" class="form-input" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hora</label>
                        <input type="time" name="time" id="trainingTime" class="form-input" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Lugar</label>
                    <input type="text" name="location" id="trainingLocation" class="form-input" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Duración (minutos)</label>
                    <input type="number" name="duration" id="trainingDuration" class="form-input" placeholder="Ej: 90">
                </div>
                <button type="submit" class="btn btn-primary w-full">Guardar</button>
                <button type="button" onclick="closeTrainingModal()" class="btn btn-gray w-full mt-2">Cancelar</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <style>
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); align-items: center; justify-content: center; z-index: 1100; }
        .modal.active { display: flex; }
        .modal-content { background: white; border-radius: 20px; max-width: 500px; width: 90%; max-height: 90vh; overflow-y: auto; }
        .modal-header { background: #1E3A8A; color: white; padding: 1.25rem 1.5rem; border-radius: 20px 20px 0 0; display: flex; justify-content: space-between; align-items: center; }
        .modal-header button { background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer; }
        .modal-body { padding: 1.5rem; }
        .btn-primary { background: #1E3A8A; color: white; padding: 0.6rem 1.5rem; border-radius: 12px; border: none; cursor: pointer; transition: all 0.3s; font-weight: 600; }
        .btn-primary:hover { background: #172554; }
        .btn-gray { background: #4B5563; color: white; padding: 0.6rem 1.5rem; border-radius: 12px; border: none; cursor: pointer; transition: all 0.3s; font-weight: 600; }
        .btn-gray:hover { background: #374151; }
        .form-input, .form-select, .form-textarea { width: 100%; padding: 0.75rem 1rem; border: 2px solid #E5E7EB; border-radius: 12px; transition: all 0.3s; font-family: 'Inter', sans-serif; font-size: 0.9rem; }
        .form-input:focus, .form-select:focus, .form-textarea:focus { outline: none; border-color: #1E3A8A; box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1); }
        .form-label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: #111827; font-size: 0.9rem; }
    </style>

    <script>
        function openTrainingModal() {
            document.getElementById('trainingModal').classList.add('active');
            document.getElementById('trainingModalTitle').textContent = 'Agregar Entrenamiento';
            document.getElementById('trainingForm').action = '/coach/trainings';
            document.getElementById('trainingForm').reset();
        }
        function closeTrainingModal() {
            document.getElementById('trainingModal').classList.remove('active');
        }
        function editTraining(id) {
            fetch('/coach/trainings/api/' + id)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    document.getElementById('trainingModalTitle').textContent = 'Editar Entrenamiento';
                    document.getElementById('trainingForm').action = '/coach/trainings/' + id;
                    document.getElementById('trainingTitle').value = data.title;
                    document.getElementById('trainingDescription').value = data.description || '';
                    document.getElementById('trainingDate').value = data.date.split('T')[0];
                    document.getElementById('trainingTime').value = data.time;
                    document.getElementById('trainingLocation').value = data.location;
                    document.getElementById('trainingDuration').value = data.duration || '';
                    document.getElementById('trainingModal').classList.add('active');
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('Error al cargar los datos');
                });
        }
        window.onclick = function(event) {
            var modal = document.getElementById('trainingModal');
            if (event.target === modal) closeTrainingModal();
        }
    </script>
</body>
</html>