<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Entrenamientos | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            align-items: center; justify-content: center;
            z-index: 1100;
        }
        .modal.active { display: flex; }
        .modal-content { animation: slideIn 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
        @keyframes slideIn {
            from { transform: translateY(-30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-[#1E3A8A]">🏋️ Gestión de Entrenamientos</h1>
                <p class="text-gray-500 mt-1">Organiza, calendariza y planifica las jornadas físicas del equipo</p>
            </div>
            <button onclick="openTrainingModal()" class="bg-[#1E3A8A] hover:bg-[#172554] text-white font-semibold px-5 py-2.5 rounded-xl transition duration-200 flex items-center gap-2 shadow-sm mt-4 md:mt-0 active:scale-95">
                <span class="text-base">➕</span> Agregar Entrenamiento
            </button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 text-center transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
                <div class="text-3xl mb-2">🏋️</div>
                <div class="text-3xl font-extrabold text-[#1E3A8A]"><%= trainings.length %></div>
                <div class="text-sm font-medium text-gray-400 mt-0.5">Total Entrenamientos</div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 text-center transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
                <div class="text-3xl mb-2">📅</div>
                <div class="text-3xl font-extrabold text-blue-600"><%= trainings.filter(function(t) { return new Date(t.date) >= new Date(); }).length %></div>
                <div class="text-sm font-medium text-gray-400 mt-0.5">Próximas Sesiones</div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 text-center transition duration-300 hover:-translate-y-0.5 hover:shadow-md">
                <div class="text-3xl mb-2">✅</div>
                <div class="text-3xl font-extrabold text-emerald-500">Asistencia</div>
                <div class="text-sm font-medium text-gray-400 mt-0.5">Módulo de Control</div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-[#1E3A8A] text-white">
                            <th class="px-6 py-3.5 font-semibold">📌 Título</th>
                            <th class="px-6 py-3.5 font-semibold">📝 Descripción</th>
                            <th class="px-6 py-3.5 font-semibold">📅 Fecha</th>
                            <th class="px-6 py-3.5 font-semibold">🕐 Hora</th>
                            <th class="px-6 py-3.5 font-semibold">📍 Lugar</th>
                            <th class="px-6 py-3.5 font-semibold text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 text-gray-700 font-medium">
                        <% if (trainings && trainings.length > 0) { %>
                            <% for (var i = 0; i < trainings.length; i++) { var t = trainings[i]; %>
                                <tr class="hover:bg-gray-50/70 transition duration-150">
                                    <td class="px-6 py-4 font-bold text-gray-900"><%= t.title %></td>
                                    <td class="px-6 py-4 text-gray-500 max-w-xs truncate" title="<%= t.description %>">
                                        <%= t.description ? t.description.substring(0, 50) + (t.description.length > 50 ? '...' : '') : '-' %>
                                    </td>
                                    <td class="px-6 py-4 text-gray-600"><%= new Date(t.date).toLocaleDateString('es-CO') %></td>
                                    <td class="px-6 py-4"><span class="bg-gray-100 text-gray-800 px-2.5 py-1 rounded-md font-mono text-xs"><%= t.time %></span></td>
                                    <td class="px-6 py-4 text-gray-600"><%= t.location %></td>
                                    <td class="px-6 py-4">
                                        <div class="flex gap-3 justify-center items-center">
                                            <button onclick="editTraining('<%= t.id %>')" class="text-amber-500 hover:text-amber-600 text-lg transition hover:scale-110" title="Editar entrenamiento">✏️</button>
                                            <a href="/coach/trainings/<%= t.id %>/delete" class="text-rose-500 hover:text-rose-600 text-lg transition hover:scale-110" onclick="return confirm('¿Estás seguro de que deseas eliminar permanentemente esta sesión de entrenamiento?')" title="Eliminar entrenamiento">🗑️</a>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        <% ] else { %>
                            <tr>
                                <td colspan="6" class="text-center py-12 text-gray-400">
                                    <span class="text-5xl block mb-3">🏋️</span>
                                    <p class="text-lg font-bold text-gray-600">No hay sesiones de entrenamiento programadas</p>
                                    <p class="text-xs text-gray-400 mt-1">Crea una nueva jornada para desplegarla en el calendario de los jugadores.</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-10 text-center">
            <a href="/coach/dashboard" class="bg-gray-600 hover:bg-gray-700 text-white font-semibold px-6 py-2.5 rounded-xl text-sm transition inline-block shadow-sm">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <div id="trainingModal" class="modal">
        <div class="modal-content bg-white rounded-2xl max-w-md w-11/12 overflow-hidden shadow-2xl">
            <div class="bg-[#1E3A8A] text-white px-6 py-4 flex justify-between items-center">
                <h3 id="trainingModalTitle" class="text-lg font-bold">➕ Agregar Entrenamiento</h3>
                <button onclick="closeTrainingModal()" class="text-3xl font-light leading-none hover:rotate-90 transition duration-200">&times;</button>
            </div>
            <form id="trainingForm" method="POST" action="/coach/trainings" class="p-6 max-h-[80vh] overflow-y-auto">
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-900 mb-1.5">📌 Título del Bloque</label>
                    <input type="text" name="title" id="trainingTitle" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] text-sm font-medium text-gray-800" placeholder="Ej: Práctica Táctica o Reducidos" required>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-900 mb-1.5">📝 Objetivos / Descripción</label>
                    <textarea name="description" id="trainingDescription" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] text-sm font-medium text-gray-800 resize-none" rows="3" placeholder="Detalla los ejercicios o el enfoque del día..."></textarea>
                </div>
                <div class="grid grid-cols-2 gap-3 mb-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-1.5">📅 Fecha</label>
                        <input type="date" name="date" id="trainingDate" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] text-sm font-medium text-gray-800" required>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 mb-1.5">🕐 Hora de Inicio</label>
                        <input type="time" name="time" id="trainingTime" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] text-sm font-medium text-gray-800" required>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-900 mb-1.5">📍 Ubicación / Cancha</label>
                    <input type="text" name="location" id="trainingLocation" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] text-sm font-medium text-gray-800" placeholder="Ej: Cancha Sintética #2" required>
                </div>
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-900 mb-1.5">⏱️ Duración Total (minutos)</label>
                    <input type="number" name="duration" id="trainingDuration" class="w-full px-3 py-2 border-2 border-gray-200 rounded-xl focus:outline-none focus:border-[#1E3A8A] text-sm font-medium text-gray-800" placeholder="Ej: 90" min="1">
                </div>
                
                <div class="flex flex-col gap-2 pt-2">
                    <button type="submit" class="w-full bg-[#1E3A8A] hover:bg-[#172554] text-white font-bold py-2.5 rounded-xl transition shadow-sm">💾 Guardar Entrenamiento</button>
                    <button type="button" onclick="closeTrainingModal()" class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2.5 rounded-xl transition">❌ Cancelar</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        function openTrainingModal() {
            document.getElementById('trainingModal').classList.add('active');
            document.getElementById('trainingModalTitle').textContent = '➕ Agregar Entrenamiento';
            document.getElementById('trainingForm').action = '/coach/trainings';
            document.getElementById('trainingForm').reset();
        }
        
        function closeTrainingModal() {
            document.getElementById('trainingModal').classList.remove('active');
        }
        
        function editTraining(id) {
            fetch('/coach/trainings/api/' + id)
                .then(function(response) {
                    if (!response.ok) throw new Error('Error al extraer los datos del entrenamiento');
                    return response.json();
                })
                .then(function(data) {
                    document.getElementById('trainingModalTitle').textContent = '✏️ Editar Entrenamiento';
                    document.getElementById('trainingForm').action = '/coach/trainings/' + id;
                    document.getElementById('trainingTitle').value = data.title || '';
                    document.getElementById('trainingDescription').value = data.description || '';
                    if (data.date) {
                        document.getElementById('trainingDate').value = data.date.split('T')[0];
                    }
                    document.getElementById('trainingTime').value = data.time || '';
                    document.getElementById('trainingLocation').value = data.location || '';
                    document.getElementById('trainingDuration').value = data.duration || '';
                    document.getElementById('trainingModal').classList.add('active');
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('❌ Ocurrió un error al cargar la información técnica de la sesión.');
                });
        }
        
        window.onclick = function(event) {
            var modal = document.getElementById('trainingModal');
            if (event.target === modal) closeTrainingModal();
        }
        
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                var modal = document.getElementById('trainingModal');
                if (modal.classList.contains('active')) closeTrainingModal();
            }
        });
    </script>
</body>
</html>