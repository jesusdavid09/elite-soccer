<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elite Soccer Academy</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
        .title-font {
            font-family: 'Bebas Neue', cursive;
            letter-spacing: 2px;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .hero-content {
            animation: fadeInUp 0.8s ease;
        }
        .feature-card {
            transition: all 0.3s ease;
            border: 1px solid #E5E7EB;
        }
        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            border-color: #1E3A8A;
        }
        .btn-hero {
            background: #1E3A8A;
            color: white;
            transition: all 0.3s ease;
        }
        .btn-hero:hover {
            background: #172554;
            transform: scale(1.05);
        }
        .btn-hero-outline {
            background: transparent;
            color: white;
            border: 2px solid white;
            transition: all 0.3s ease;
        }
        .btn-hero-outline:hover {
            background: white;
            color: #1E3A8A;
            transform: scale(1.05);
        }
        .bg-dark-blue { background-color: #1E3A8A; }
        .text-sport-blue { color: #1E3A8A; }
        .from-dark-blue { --tw-gradient-from: #1E3A8A; }
        .to-sport-blue { --tw-gradient-to: #172554; }
    </style>
</head>
<body>
    <!-- Hero Section -->
    <div class="relative min-h-screen bg-gradient-to-br from-[#1E3A8A] to-[#172554] overflow-hidden">
        <div class="absolute inset-0 bg-black/30 z-0"></div>
        <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1522778119026-d364fcece646?w=1600')] bg-cover bg-center opacity-20 z-0"></div>
        
        <div class="relative z-10 container mx-auto px-4 py-16 min-h-screen flex flex-col justify-center">
            <div class="hero-content text-center text-white max-w-4xl mx-auto">
                <!-- Escudo -->
                <div class="inline-block p-4 bg-white/10 backdrop-blur-lg rounded-full mb-6">
                    <span class="text-7xl">⚽</span>
                </div>
                
                <!-- Título -->
                <h1 class="text-5xl md:text-7xl font-bold mb-4 title-font tracking-wider">ELITE SOCCER</h1>
                <p class="text-xl md:text-2xl mb-2 tracking-widest font-light">ACADEMY</p>
                
                <!-- Lema -->
                <p class="text-base md:text-lg text-white/80 max-w-2xl mx-auto mb-8">
                    Disciplina • Compromiso • Excelencia
                </p>
                
                <!-- Frase motivacional -->
                <p class="text-md italic text-white/70 max-w-xl mx-auto mb-12">
                    "La excelencia no es un acto, sino un hábito"
                </p>
                
                <!-- Botones -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/login" class="btn-hero px-8 py-3 rounded-full font-semibold shadow-lg">
                        Iniciar Sesión
                    </a>
                    <a href="/register" class="btn-hero-outline px-8 py-3 rounded-full font-semibold">
                        Registrarse
                    </a>
                </div>
            </div>
            
            <!-- Scroll indicator -->
            <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
                <div class="w-6 h-10 border-2 border-white rounded-full flex justify-center">
                    <div class="w-1 h-3 bg-white rounded-full mt-2"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sección de características -->
    <div class="py-20 bg-white">
        <div class="container mx-auto px-4">
            <h2 class="text-3xl md:text-4xl font-bold text-center text-[#1E3A8A] mb-4 title-font">¿POR QUÉ ELEGIRNOS?</h2>
            <p class="text-center text-gray-500 mb-12 max-w-2xl mx-auto">
                Somos una academia comprometida con la formación integral de futbolistas
            </p>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="feature-card text-center p-6 bg-gray-50 rounded-2xl shadow-lg">
                    <div class="text-5xl mb-4">🏆</div>
                    <h3 class="text-xl font-bold mb-2 text-[#1E3A8A]">Metodología Profesional</h3>
                    <p class="text-gray-500">Entrenamientos basados en las mejores academias del mundo</p>
                </div>
                <div class="feature-card text-center p-6 bg-gray-50 rounded-2xl shadow-lg">
                    <div class="text-5xl mb-4">👥</div>
                    <h3 class="text-xl font-bold mb-2 text-[#1E3A8A]">Cuerpo Técnico Calificado</h3>
                    <p class="text-gray-500">Profesionales con experiencia y pasión por el fútbol</p>
                </div>
                <div class="feature-card text-center p-6 bg-gray-50 rounded-2xl shadow-lg">
                    <div class="text-5xl mb-4">⚽</div>
                    <h3 class="text-xl font-bold mb-2 text-[#1E3A8A]">Instalaciones de Primera</h3>
                    <p class="text-gray-500">Canchas y equipamiento de alta calidad</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Llamada a la acción -->
    <div class="py-20 bg-gradient-to-r from-[#1E3A8A] to-[#172554]">
        <div class="container mx-auto px-4 text-center text-white">
            <h2 class="text-3xl md:text-4xl font-bold mb-4 title-font">¿LISTO PARA COMENZAR?</h2>
            <p class="text-lg mb-8 opacity-90">Únete a Elite Soccer Academy y lleva tu talento al siguiente nivel</p>
            <a href="/register" class="inline-block bg-white text-[#1E3A8A] px-8 py-3 rounded-full font-semibold hover:scale-105 transition transform shadow-lg">
                Comienza ahora
            </a>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-[#172554] text-white py-8">
        <div class="container mx-auto px-4 text-center">
            <div class="flex justify-center space-x-6 mb-4">
                <span class="text-2xl">⚽</span>
                <span class="text-2xl">🏆</span>
                <span class="text-2xl">🎯</span>
            </div>
            <p class="text-sm text-gray-300">
                &copy; 2025 Elite Soccer Academy - Disciplina • Compromiso • Excelencia
            </p>
            <p class="text-xs text-gray-400 mt-2">
                Todos los derechos reservados
            </p>
        </div>
    </footer>
</body>
</html>