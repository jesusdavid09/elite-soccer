<nav class="sticky top-0 z-50 bg-[#1E3A8A] text-white px-4 md:px-8 py-4 shadow-md border-b-4 border-white">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row justify-between items-center gap-4">
        
        <div class="flex items-center gap-3 shrink-0">
            <span class="text-3xl select-none">⚽</span>
            <div>
                <div class="font-extrabold text-xl tracking-wider font-['Poppins'] leading-tight">ELITE SOCCER</div>
                <div class="text-[10px] font-bold text-blue-400 tracking-[0.2em] uppercase leading-none">Academy</div>
            </div>
        </div>

        <div class="flex flex-wrap justify-center items-center gap-x-5 gap-y-2 text-sm font-medium">
            <% if (user && user.role === 'coach') { %>
                <a href="/coach/dashboard" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">🏠 Inicio</a>
                <a href="/coach/players" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">👥 Jugadores</a>
                <a href="/coach/approve-players" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200 flex items-center gap-1.5">
                    📋 Aprobar
                    <% if (pendingCount && pendingCount > 0) { %>
                        <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full animate-pulse min-w-[18px] text-center">
                            <%= pendingCount %>
                        </span>
                    <% } %>
                </a>
                <a href="/coach/trainings" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">🏋️ Entrenamientos</a>
                <a href="/coach/matches" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">⚽ Partidos</a>
                <a href="/coach/announcements" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">📢 Anuncios</a>
                <a href="/coach/attendance" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">✅ Asistencia</a>
            <% } else if (user && user.role === 'player') { %>
                <a href="/player/dashboard" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">🏠 Inicio</a>
                <a href="/player/attendance" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">✅ Asistencia</a>
                <a href="/player/announcements" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">📢 Anuncios</a>
                <a href="/player/profile" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">👤 Mi Perfil</a>
            <% } else { %>
                <a href="/" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">🏠 Inicio</a>
                <a href="/login" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">🔑 Iniciar Sesión</a>
                <a href="/register" class="py-1 border-b-2 border-transparent hover:border-white transition duration-200">📝 Registrarse</a>
            <% } %>
        </div>

        <div class="flex items-center gap-4 text-sm shrink-0">
            <% if (user) { %>
                <span class="font-medium hidden sm:inline">
                    <%= user.full_name %>
                    <span class="text-xs text-blue-300 ml-1 font-normal">
                        (<%= user.role === 'coach' ? 'Entrenador' : 'Jugador' %>)
                    </span>
                </span>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold text-xs px-4 py-2 rounded-full transition duration-200 active:scale-95">
                    🚪 Salir
                </a>
            <% } else { %>
                <a href="/login" class="bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold text-xs px-4 py-2 rounded-full transition duration-200 active:scale-95">
                    🔑 Iniciar Sesión
                </a>
            <% } %>
        </div>
        
    </div>
</nav>