<div class="mb-8">
    <h1 class="text-3xl font-bold text-[#1E3A8A]">📢 Anuncios del Equipo</h1>
    <p class="text-gray-500 mt-1">Mantente informado de las novedades del club</p>
</div>

<% if (announcements && announcements.length > 0) { %>
    <div class="space-y-4">
        <% announcements.forEach(a => { %>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 transition duration-300 hover:-translate-y-1 hover:shadow-md hover:shadow-blue-900/5">
                <h3 class="text-xl font-bold text-gray-900"><%= a.title %></h3>
                <p class="text-gray-600 mt-2 whitespace-pre-line"><%= a.content %></p>
                
                <div class="flex items-center gap-3 mt-4 pt-4 border-t border-gray-100">
                    <div class="w-9 h-9 bg-[#1E3A8A] rounded-full flex items-center justify-center text-white font-bold text-sm shrink-0 uppercase select-none">
                        <%= a.author_name ? a.author_name.charAt(0).toUpperCase() : 'A' %>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-gray-900"><%= a.author_name || 'Administrador' %></p>
                        <p class="text-xs text-gray-400">
                            <%= new Date(a.created_at).toLocaleString('es-CO', { dateStyle: 'medium', timeStyle: 'short' }) %>
                        </p>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } else { %>
    <div class="bg-white rounded-2xl border border-gray-200 p-12 text-center shadow-sm max-w-2xl mx-auto">
        <div class="text-6xl mb-4 select-none">📢</div>
        <h3 class="text-2xl font-bold text-gray-600 mb-2">No hay anuncios publicados</h3>
        <p class="text-gray-400">Aún no hay novedades registradas en el club.</p>
        <p class="text-gray-400 text-sm mt-1">Vuelve más tarde para ver las actualizaciones del cuerpo técnico.</p>
    </div>
<% } %>

<div class="mt-8 text-center">
    <a href="/player/dashboard" class="inline-flex items-center gap-2 bg-[#1E3A8A] hover:bg-[#172554] text-white font-semibold px-6 py-2.5 rounded-xl transition duration-200 active:scale-95 shadow-sm hover:shadow-md">
        <span>←</span> Volver al Dashboard
    </a>
</div>