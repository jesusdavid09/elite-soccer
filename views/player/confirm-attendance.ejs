<div class="mb-8">
    <h1 class="text-3xl font-bold text-[#1E3A8A]">✅ Confirmar Asistencia</h1>
    <p class="text-gray-500 mt-1">Selecciona tu disponibilidad para los próximos eventos de la academia</p>
</div>

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-8 transition duration-300 hover:shadow-md">
    <div class="bg-[#1E3A8A] text-white px-6 py-3 font-semibold text-lg flex items-center gap-2">
        <span>🏋️</span> Entrenamientos Próximos
    </div>
    
    <% if (upcomingTrainings && upcomingTrainings.length > 0) { %>
        <div class="divide-y divide-gray-100">
            <% upcomingTrainings.forEach(function(t) { %>
                <div class="flex flex-col sm:flex-row justify-between sm:items-center p-6 gap-4 hover:bg-gray-50/50 transition duration-150" id="training-<%= t.id %>">
                    <div>
                        <div class="font-bold text-gray-900 text-base"><%= t.title %></div>
                        <div class="text-sm text-gray-500 mt-1 flex flex-wrap items-center gap-x-2 gap-y-0.5">
                            <span class="font-medium text-gray-600"><%= new Date(t.date).toLocaleDateString('es-CO') %></span>
                            <span class="text-gray-300">•</span>
                            <span><%= t.time %></span>
                            <span class="text-gray-300">•</span>
                            <span class="text-blue-600 font-medium"><%= t.location %></span>
                        </div>
                    </div>
                    <div class="flex gap-2 shrink-0 flex-wrap">
                        <button onclick="confirmAttendance('training', '<%= t.id %>', 'yes')" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-sm px-4 py-2 rounded-xl transition duration-200 active:scale-95 shadow-sm">
                            ✅ Sí
                        </button>
                        <button onclick="confirmAttendance('training', '<%= t.id %>', 'maybe')" class="bg-amber-500 hover:bg-amber-600 text-white font-bold text-sm px-4 py-2 rounded-xl transition duration-200 active:scale-95 shadow-sm">
                            🟡 Tal vez
                        </button>
                        <button onclick="askJustification('training', '<%= t.id %>')" class="bg-red-500 hover:bg-red-600 text-white font-bold text-sm px-4 py-2 rounded-xl transition duration-200 active:scale-95 shadow-sm">
                            ❌ No
                        </button>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="p-8 text-center text-gray-400">
            <div class="text-4xl mb-2 select-none">📅</div>
            <p>No hay entrenamientos agendados próximamente.</p>
        </div>
    <% } %>
</div>

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-8 transition duration-300 hover:shadow-md">
    <div class="bg-[#1E3A8A] text-white px-6 py-3 font-semibold text-lg flex items-center gap-2">
        <span>⚽</span> Partidos Oficiales
    </div>
    
    <% if (upcomingMatches && upcomingMatches.length > 0) { %>
        <div class="divide-y divide-gray-100">
            <% upcomingMatches.forEach(function(m) { %>
                <div class="flex flex-col sm:flex-row justify-between sm:items-center p-6 gap-4 hover:bg-gray-50/50 transition duration-150" id="match-<%= m.id %>">
                    <div>
                        <div class="font-bold text-gray-900 text-base">Rival: <span class="text-blue-900"><%= m.opponent %></span></div>
                        <div class="text-sm text-gray-500 mt-1 flex flex-wrap items-center gap-x-2 gap-y-0.5">
                            <span class="font-medium text-gray-600"><%= new Date(m.date).toLocaleDateString('es-CO') %></span>
                            <span class="text-gray-300">•</span>
                            <span><%= m.time %></span>
                            <span class="text-gray-300">•</span>
                            <span class="text-blue-600 font-medium"><%= m.location %></span>
                        </div>
                    </div>
                    <div class="flex gap-2 shrink-0 flex-wrap">
                        <button onclick="confirmAttendance('match', '<%= m.id %>', 'yes')" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-sm px-4 py-2 rounded-xl transition duration-200 active:scale-95 shadow-sm">
                            ✅ Sí
                        </button>
                        <button onclick="confirmAttendance('match', '<%= m.id %>', 'maybe')" class="bg-amber-500 hover:bg-amber-600 text-white font-bold text-sm px-4 py-2 rounded-xl transition duration-200 active:scale-95 shadow-sm">
                            🟡 Tal vez
                        </button>
                        <button onclick="askJustification('match', '<%= m.id %>')" class="bg-red-500 hover:bg-red-600 text-white font-bold text-sm px-4 py-2 rounded-xl transition duration-200 active:scale-95 shadow-sm">
                            ❌ No
                        </button>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="p-8 text-center text-gray-400">
            <div class="text-4xl mb-2 select-none">⚽</div>
            <p>No hay partidos programados en el calendario actual.</p>
        </div>
    <% } %>
</div>

<div class="mt-8 text-center">
    <a href="/player/dashboard" class="inline-flex items-center gap-2 bg-[#1E3A8A] hover:bg-[#172554] text-white font-semibold px-6 py-2.5 rounded-xl transition duration-200 active:scale-95 shadow-sm hover:shadow-md">
        <span>←</span> Volver al Dashboard
    </a>
</div>

<div id="justificationModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm items-center justify-center z-[1100] px-4">
    <div class="bg-white rounded-2xl max-w-md w-full shadow-2xl overflow-hidden transform transition-all translate-y-0 scale-100 opacity-100">
        <div class="bg-[#1E3A8A] text-white px-6 py-4 flex justify-between items-center">
            <h3 class="text-lg font-bold flex items-center gap-2">📝 Justificar Ausencia</h3>
            <button onclick="closeJustificationModal()" class="text-2xl font-light hover:rotate-90 transition duration-200 leading-none">&times;</button>
        </div>
        <div class="p-6">
            <div class="mb-4">
                <label class="block text-sm font-semibold text-gray-900 mb-1.5">Motivo Principal</label>
                <select id="reasonSelect" class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-2.5 focus:outline-none focus:border-[#1E3A8A] focus:ring-4 focus:ring-blue-900/10 transition">
                    <option value="">Seleccionar motivo...</option>
                    <option value="Estudio">📚 Estudio</option>
                    <option value="Trabajo">💼 Trabajo</option>
                    <option value="Enfermedad">🤒 Enfermedad / Lesión</option>
                    <option value="Viaje">✈️ Viaje</option>
                    <option value="Compromiso familiar">👨‍👩‍👧 Compromiso familiar</option>
                    <option value="Otro">📝 Otro</option>
                </select>
            </div>
            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-900 mb-1.5">Detalles Adicionales</label>
                <textarea id="justificationText" class="w-full bg-gray-50 border border-gray-200 text-gray-900 rounded-xl px-4 py-2.5 focus:outline-none focus:border-[#1E3A8A] focus:ring-4 focus:ring-blue-900/10 transition resize-none" rows="3" placeholder="Escribe una breve explicación de tu ausencia..."></textarea>
            </div>
            <div class="flex gap-3">
                <button onclick="closeJustificationModal()" class="flex-1 bg-gray-500 hover:bg-gray-600 text-white font-semibold py-2.5 rounded-xl transition duration-200 active:scale-95">
                    Cancelar
                </button>
                <button onclick="submitJustification()" class="flex-1 bg-[#1E3A8A] hover:bg-[#172554] text-white font-semibold py-2.5 rounded-xl transition duration-200 active:scale-95">
                    Enviar Reporte
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let pendingJustification = { type: null, id: null };

    async function confirmAttendance(type, id, status, justification = null) {
        try {
            const response = await fetch('/player/attendance/confirm', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ type, id, status, justification })
            });
            
            const data = await response.json();
            
            if (data.success) {
                location.reload();
            } else {
                alert('❌ El servidor no pudo procesar la solicitud.');
            }
        } catch (error) {
            console.error('Error al actualizar asistencia:', error);
            alert('❌ Ocurrió un error de red al guardar tu confirmación.');
        }
    }

    function askJustification(type, id) {
        pendingJustification = { type, id };
        const modal = document.getElementById('justificationModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.getElementById('reasonSelect').value = '';
        document.getElementById('justificationText').value = '';
    }

    function submitJustification() {
        const reason = document.getElementById('reasonSelect').value;
        const explanation = document.getElementById('justificationText').value.trim();
        
        if (!reason) {
            alert('⚠️ Por favor selecciona el motivo de tu inasistencia.');
            return;
        }
        
        const finalJustification = reason + (explanation ? ` - ${explanation}` : '');
        confirmAttendance(pendingJustification.type, pendingJustification.id, 'no', finalJustification);
        closeJustificationModal();
    }

    function closeJustificationModal() {
        const modal = document.getElementById('justificationModal');
        modal.classList.remove('flex');
        modal.classList.add('hidden');
        pendingJustification = { type: null, id: null };
    }

    // Cerrar modal al interactuar con el fondo o teclado
    window.addEventListener('click', (e) => {
        const modal = document.getElementById('justificationModal');
        if (e.target === modal) closeJustificationModal();
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeJustificationModal();
    });
</script>