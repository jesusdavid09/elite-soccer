<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirmar Asistencia | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>

    <main class="container mx-auto px-4 py-8 max-w-4xl">
        <!-- Contenido -->
        <h1 class="text-3xl font-bold text-[#1E3A8A] mb-8">✅ Confirmar Asistencia</h1>

        <!-- Entrenamientos -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden mb-8 border border-gray-200">
            <!-- ... contenido ... -->
        </div>

        <!-- Partidos -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-200">
            <!-- ... contenido ... -->
        </div>

        <div class="mt-8 text-center">
            <a href="/player/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg transition inline-block">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <!-- MODAL JUSTIFICACIÓN - ANTES DEL FOOTER -->
    <div id="justificationModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="text-xl font-bold">Justificación</h3>
                <button onclick="closeJustificationModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Motivo</label>
                    <select id="reasonSelect" class="form-select">
                        <option value="">Seleccionar</option>
                        <option value="Estudio">📚 Estudio</option>
                        <option value="Trabajo">💼 Trabajo</option>
                        <option value="Enfermedad">🤒 Enfermedad</option>
                        <option value="Viaje">✈️ Viaje</option>
                        <option value="Compromiso familiar">👨‍👩‍👧 Compromiso</option>
                        <option value="Otro">📝 Otro</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Explicación</label>
                    <textarea id="justificationText" class="form-textarea" rows="3" placeholder="Explicación..."></textarea>
                </div>
                <div class="flex gap-3">
                    <button onclick="closeJustificationModal()" class="btn btn-gray flex-1">Cancelar</button>
                    <button onclick="submitJustification()" class="btn btn-primary flex-1">Enviar</button>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        // Funciones de confirmación y justificación
        // ... (mantén tu código JavaScript existente)
    </script>
</body>
</html>