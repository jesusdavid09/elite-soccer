<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Panel | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Banner -->
        <div class="bg-gradient-to-r from-[#1E3A8A] to-[#172554] rounded-2xl p-8 text-white mb-8 shadow-lg">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center text-3xl">⚽</div>
                <div>
                    <h1 class="text-2xl font-bold">¡Bienvenido, <%= user.full_name %>!</h1>
                    <p class="text-white/80">"La excelencia no es un acto, sino un hábito"</p>
                </div>
            </div>
        </div>

        <!-- Botones de acción -->
        <div class="grid grid-cols-2 gap-4 mb-8">
            <a href="/player/attendance" class="bg-[#1E3A8A] hover:bg-[#172554] text-white p-4 rounded-xl text-center font-bold transition flex items-center justify-center gap-2">
                ✅ Confirmar Asistencia
            </a>
            <a href="/player/profile" class="bg-[#1E3A8A] hover:bg-[#172554] text-white p-4 rounded-xl text-center font-bold transition flex items-center justify-center gap-2">
                👤 Mi Perfil
            </a>
            <a href="/player/announcements" class="bg-[#1E3A8A] hover:bg-[#172554] text-white p-4 rounded-xl text-center font-bold transition flex items-center justify-center gap-2 col-span-2">
                📢 Ver Anuncios
            </a>
        </div>

        <!-- Perfil -->
        <div class="bg-white rounded-xl shadow-lg p-6 mb-6 border border-gray-200">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-[#1E3A8A] rounded-full flex items-center justify-center text-2xl text-white">
                    <% if (player && player.photo_url) { %>
                        <img src="<%= player.photo_url %>" class="w-full h-full object-cover rounded-full">
                    <% } else { %>
                        👤
                    <% } %>
                </div>
                <div>
                    <h2 class="text-xl font-bold"><%= player ? player.full_name : user.full_name %></h2>
                    <p>Camiseta #<%= player ? player.jersey_number : '?' %> | <%= player ? player.position : 'Sin posición' %></p>
                </div>
            </div>
        </div>

        <!-- Próximos entrenamientos -->
        <div class="bg-white rounded-xl shadow-lg p-6 mb-6 border border-gray-200">
            <h2 class="text-xl font-bold text-[#1E3A8A] mb-4">🏋️ Próximos Entrenamientos</h2>
            <% if (upcomingTrainings && upcomingTrainings.length > 0) { %>
                <% upcomingTrainings.forEach(t => { %>
                    <div class="flex items-center gap-3 p-2 bg-gray-50 rounded-lg mb-2">
                        <span class="text-2xl">🏋️</span>
                        <div>
                            <div class="font-bold"><%= t.title %></div>
                            <div class="text-sm text-gray-500"><%= new Date(t.date).toLocaleDateString() %> - <%= t.time %></div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="text-gray-500 text-center py-4">No hay entrenamientos próximos</p>
            <% } %>
        </div>

        <!-- Próximos partidos -->
        <div class="bg-white rounded-xl shadow-lg p-6 mb-6 border border-gray-200">
            <h2 class="text-xl font-bold text-[#1E3A8A] mb-4">⚽ Próximos Partidos</h2>
            <% if (upcomingMatches && upcomingMatches.length > 0) { %>
                <% upcomingMatches.forEach(m => { %>
                    <div class="flex items-center gap-3 p-2 bg-gray-50 rounded-lg mb-2">
                        <span class="text-2xl">⚽</span>
                        <div>
                            <div class="font-bold">vs <%= m.opponent %></div>
                            <div class="text-sm text-gray-500"><%= new Date(m.date).toLocaleDateString() %> - <%= m.time %></div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="text-gray-500 text-center py-4">No hay partidos próximos</p>
            <% } %>
        </div>

        <!-- Botón Volver -->
        <div class="mt-8 text-center">
            <a href="/player/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg transition inline-block">
                ← Volver al Dashboard
            </a>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>