<div class="relative bg-gradient-to-br from-[#1E3A8A] to-[#172554] rounded-2xl p-6 md:p-8 text-white shadow-md overflow-hidden mb-8 transition duration-300 hover:shadow-lg">
    <div class="absolute right-0 top-0 translate-x-4 -translate-y-4 text-white/5 text-9xl font-black select-none pointer-events-none">
        FC
    </div>
    <div class="relative flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 md:w-16 md:h-16 bg-white/10 backdrop-blur-md rounded-full flex items-center justify-center text-3xl select-none shrink-0 border border-white/20 shadow-inner">
                ⚽
            </div>
            <div>
                <h1 class="text-2xl md:text-3xl font-bold tracking-tight">¡Bienvenido, <%= user.full_name %>!</h1>
                <p class="text-blue-200/90 text-sm italic mt-0.5">"La excelencia no es un acto, sino un hábito"</p>
            </div>
        </div>
        
        <div class="flex flex-wrap gap-2 md:self-center">
            <span class="bg-white/10 backdrop-blur-md border border-white/10 rounded-xl px-4 py-1.5 text-xs font-medium uppercase tracking-wider">
                📅 <%= new Date().toLocaleDateString('es-CO', { weekday: 'short', day: 'numeric', month: 'short' }) %>
            </span>
            <% if (player) { %>
                <span class="bg-white/10 backdrop-blur-md border border-white/10 rounded-xl px-4 py-1.5 text-xs font-bold text-amber-300">
                    👕 Dor. <%= player.jersey_number %>
                </span>
                <span class="bg-white/10 backdrop-blur-md border border-white/10 rounded-xl px-4 py-1.5 text-xs font-semibold">
                    📌 <%= player.position || 'Sin posición' %>
                </span>
            <% } %>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <div class="lg:col-span-1 space-y-6">
        
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm transition duration-300 hover:shadow-md">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-gradient-to-tr from-[#1E3A8A] to-blue-600 rounded-full flex items-center justify-center text-2xl text-white font-bold shrink-0 shadow-md overflow-hidden border-2 border-white ring-4 ring-gray-100">
                    <% if (player && player.photo_url) { %>
                        <img src="<%= player.photo_url %>" alt="<%= player.full_name %>" class="w-100 h-100 object-cover">
                    <% } else { %>
                        👤
                    <% } %>
                </div>
                <div class="min-w-0">
                    <h2 class="text-lg font-bold text-gray-900 truncate"><%= player ? player.full_name : user.full_name %></h2>
                    <p class="text-sm font-medium text-gray-500 flex items-center gap-1.5 mt-0.5">
                        <span>Camiseta #<%= player ? player.jersey_number : '?' %></span>
                        <span class="text-gray-300">•</span>
                        <span class="text-blue-700 font-semibold"><%= player && player.position ? player.position : 'Sin posición' %></span>
                    </p>
                    <p class="text-xs text-gray-400 truncate mt-1">📧 <%= user.email %></p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 p-4 shadow-sm">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider px-2 mb-3">Accesos Directos</h3>
            <div class="grid grid-cols-1 gap-2">
                <a href="/player/attendance" class="flex items-center gap-3 bg-[#1E3A8A] hover:bg-[#172554] text-white font-semibold p-3.5 rounded-xl transition duration-200 active:scale-98 shadow-sm">
                    <span class="text-lg">✅</span>
                    <span class="text-sm">Confirmar Asistencia</span>
                </a>
                <a href="/player/profile" class="flex items-center gap-3 bg-gray-50 hover:bg-gray-100 text-gray-700 hover:text-gray-900 font-semibold p-3.5 rounded-xl transition duration-200 active:scale-98 border border-gray-100">
                    <span class="text-lg">👤</span>
                    <span class="text-sm">Gestionar Mi Perfil</span>
                </a>
                <a href="/player/announcements" class="flex items-center gap-3 bg-gray-50 hover:bg-gray-100 text-gray-700 hover:text-gray-900 font-semibold p-3.5 rounded-xl transition duration-200 active:scale-98 border border-gray-100">
                    <span class="text-lg">📢</span>
                    <span class="text-sm">Tablón de Anuncios</span>
                </a>
            </div>
        </div>
    </div>

    <div class="lg:col-span-2 space-y-6">
        
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm transition duration-300 hover:shadow-md">
            <h2 class="text-lg font-bold text-[#1E3A8A] mb-4 flex items-center gap-2">
                <span>🏋️</span> Próximos Entrenamientos
            </h2>
            <% if (upcomingTrainings && upcomingTrainings.length > 0) { %>
                <div class="space-y-3">
                    <% upcomingTrainings.forEach(t => { %>
                        <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                            <span class="text-xl bg-blue-100 text-blue-800 p-2 rounded-lg shrink-0 select-none">🏋️</span>
                            <div class="min-w-0">
                                <div class="font-bold text-gray-900 text-sm md:text-base truncate"><%= t.title %></div>
                                <div class="text-xs md:text-sm text-gray-500 font-medium mt-0.5">
                                    <span><%= new Date(t.date).toLocaleDateString('es-CO', { dateStyle: 'medium' }) %></span>
                                    <span class="text-gray-300 mx-1">•</span>
                                    <span class="text-gray-600"><%= t.time %></span>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="text-center py-6 text-gray-400 text-sm">
                    📭 No tienes entrenamientos agendados por ahora.
                </div>
            <% } %>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm transition duration-300 hover:shadow-md">
            <h2 class="text-lg font-bold text-[#1E3A8A] mb-4 flex items-center gap-2">
                <span>⚽</span> Próximos Partidos
            </h2>
            <% if (upcomingMatches && upcomingMatches.length > 0) { %>
                <div class="space-y-3">
                    <% upcomingMatches.forEach(m => { %>
                        <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                            <span class="text-xl bg-emerald-100 text-emerald-800 p-2 rounded-lg shrink-0 select-none">⚽</span>
                            <div class="min-w-0">
                                <div class="font-bold text-gray-900 text-sm md:text-base truncate">vs <%= m.opponent %></div>
                                <div class="text-xs md:text-sm text-gray-500 font-medium mt-0.5">
                                    <span class="text-emerald-700 font-semibold"><%= new Date(m.date).toLocaleDateString('es-CO', { dateStyle: 'medium' }) %></span>
                                    <span class="text-gray-300 mx-1">•</span>
                                    <span class="text-gray-600"><%= m.time %></span>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="text-center py-6 text-gray-400 text-sm">
                    📭 No hay partidos oficiales programados.
                </div>
            <% } %>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm transition duration-300 hover:shadow-md">
            <h2 class="text-lg font-bold text-[#1E3A8A] mb-4 flex items-center gap-2">
                <span>📢</span> Últimas Novedades
            </h2>
            <% if (latestAnnouncements && latestAnnouncements.length > 0) { %>
                <div class="space-y-3">
                    <% latestAnnouncements.slice(0, 3).forEach(a => { %>
                        <div class="flex items-start gap-4 p-4 bg-gray-50/50 rounded-xl border border-gray-100">
                            <span class="text-lg bg-amber-100 text-amber-800 p-2 rounded-lg shrink-0 select-none mt-0.5">📢</span>
                            <div class="min-w-0 flex-1">
                                <div class="font-bold text-gray-900 text-sm"><%= a.title %></div>
                                <div class="text-[11px] text-gray-400 font-medium mt-0.5">
                                    <%= new Date(a.created_at).toLocaleString('es-CO', { dateStyle: 'short', timeStyle: 'short' }) %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
                <% if (latestAnnouncements.length > 3) { %>
                    <div class="text-right mt-3">
                        <a href="/player/announcements" class="text-xs font-bold text-[#1E3A8A] hover:text-[#172554] inline-flex items-center gap-1 group transition">
                            Ver todo el histórico <span class="group-hover:translate-x-0.5 transition duration-150">→</span>
                        </a>
                    </div>
                <% } %>
            <% } else { %>
                <div class="text-center py-6 text-gray-400 text-sm">
                    📭 El club no ha publicado comunicados recientes.
                </div>
            <% } %>
        </div>

    </div>
</div>