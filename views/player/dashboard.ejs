<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Panel | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #F3F4F6;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
        .card-dashboard {
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            border: 1px solid #E5E7EB;
            transition: all 0.3s ease;
        }
        .card-dashboard:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(30, 58, 138, 0.15);
        }
        .btn-action {
            background: #1E3A8A;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 1rem;
            border-radius: 12px;
            text-align: center;
            font-weight: 700;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        .btn-action:hover {
            background: #172554;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(30, 58, 138, 0.3);
        }
        .btn-action-full {
            grid-column: span 2;
        }
        .btn-volver {
            background: #1E3A8A;
            color: #FFFFFF;
            transition: all 0.3s ease;
            padding: 0.5rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            display: inline-block;
            text-decoration: none;
        }
        .btn-volver:hover {
            background: #172554;
            transform: scale(1.05);
        }
        .text-azul-rey {
            color: #1E3A8A;
        }
        .bg-azul-rey {
            background: #1E3A8A;
        }
        .player-avatar {
            width: 64px;
            height: 64px;
            background: #1E3A8A;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: #FFFFFF;
            flex-shrink: 0;
        }
        .player-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
        .event-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 0.75rem;
            background: #F9FAFB;
            border-radius: 8px;
            margin-bottom: 0.5rem;
        }
        .event-item:last-child {
            margin-bottom: 0;
        }
        .event-icon {
            font-size: 1.5rem;
        }
        .event-title {
            font-weight: 700;
            color: #111827;
        }
        .event-date {
            font-size: 0.875rem;
            color: #6B7280;
        }
        .empty-message {
            color: #6B7280;
            text-align: center;
            padding: 1rem 0;
        }
        .banner-gradient {
            background: linear-gradient(135deg, #1E3A8A 0%, #172554 100%);
            border-radius: 16px;
            padding: 2rem;
            color: #FFFFFF;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .profile-section {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .profile-name {
            font-size: 1.25rem;
            font-weight: 700;
        }
        .profile-detail {
            color: #6B7280;
            font-size: 0.9rem;
        }
        .section-title {
            font-size: 1.125rem;
            font-weight: 700;
            color: #1E3A8A;
            margin-bottom: 1rem;
        }
        .banner-stats {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 1rem;
        }
        .banner-stats span {
            background: rgba(255,255,255,0.1);
            border-radius: 9999px;
            padding: 0.25rem 1rem;
            font-size: 0.875rem;
        }
        @media (max-width: 640px) {
            .btn-action-full {
                grid-column: span 1;
            }
            .grid-cols-2 {
                grid-template-columns: 1fr;
            }
            .profile-section {
                flex-direction: column;
                text-align: center;
            }
            .player-avatar {
                width: 80px;
                height: 80px;
                font-size: 2.5rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { user: user, pendingCount: pendingCount }) %>

    <main class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Banner -->
        <div class="banner-gradient mb-8">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center text-3xl">⚽</div>
                <div>
                    <h1 class="text-2xl font-bold">¡Bienvenido, <%= user.full_name %>!</h1>
                    <p class="text-white/80 text-sm">"La excelencia no es un acto, sino un hábito"</p>
                </div>
            </div>
            <div class="banner-stats">
                <span>📅 <%= new Date().toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
                <% if (player) { %>
                    <span>👕 #<%= player.jersey_number %></span>
                    <span>📌 <%= player.position || 'Sin posición' %></span>
                <% } %>
            </div>
        </div>

        <!-- Botones de acción -->
        <div class="grid grid-cols-2 gap-4 mb-8">
            <a href="/player/attendance" class="btn-action">
                ✅ Confirmar Asistencia
            </a>
            <a href="/player/profile" class="btn-action">
                👤 Mi Perfil
            </a>
            <a href="/player/announcements" class="btn-action btn-action-full">
                📢 Ver Anuncios
            </a>
        </div>

        <!-- Perfil del Jugador -->
        <div class="card-dashboard p-6 mb-6">
            <div class="profile-section">
                <div class="player-avatar">
                    <% if (player && player.photo_url) { %>
                        <img src="<%= player.photo_url %>" alt="<%= player.full_name %>">
                    <% } else { %>
                        👤
                    <% } %>
                </div>
                <div>
                    <h2 class="profile-name"><%= player ? player.full_name : user.full_name %></h2>
                    <p class="profile-detail">
                        Camiseta #<%= player ? player.jersey_number : '?' %> 
                        <%= player && player.position ? '• ' + player.position : '• Sin posición' %>
                    </p>
                    <p class="profile-detail text-sm">
                        📧 <%= user.email %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Próximos entrenamientos -->
        <div class="card-dashboard p-6 mb-6">
            <h2 class="section-title">🏋️ Próximos Entrenamientos</h2>
            <% if (upcomingTrainings && upcomingTrainings.length > 0) { %>
                <% upcomingTrainings.forEach(t => { %>
                    <div class="event-item">
                        <span class="event-icon">🏋️</span>
                        <div>
                            <div class="event-title"><%= t.title %></div>
                            <div class="event-date"><%= new Date(t.date).toLocaleDateString() %> - <%= t.time %></div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="empty-message">📭 No hay entrenamientos próximos</p>
            <% } %>
        </div>

        <!-- Próximos partidos -->
        <div class="card-dashboard p-6 mb-6">
            <h2 class="section-title">⚽ Próximos Partidos</h2>
            <% if (upcomingMatches && upcomingMatches.length > 0) { %>
                <% upcomingMatches.forEach(m => { %>
                    <div class="event-item">
                        <span class="event-icon">⚽</span>
                        <div>
                            <div class="event-title">vs <%= m.opponent %></div>
                            <div class="event-date"><%= new Date(m.date).toLocaleDateString() %> - <%= m.time %></div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="empty-message">📭 No hay partidos próximos</p>
            <% } %>
        </div>

        <!-- Últimos anuncios -->
        <div class="card-dashboard p-6 mb-6">
            <h2 class="section-title">📢 Últimos Anuncios</h2>
            <% if (latestAnnouncements && latestAnnouncements.length > 0) { %>
                <% latestAnnouncements.slice(0, 3).forEach(a => { %>
                    <div class="event-item">
                        <span class="event-icon">📢</span>
                        <div>
                            <div class="event-title"><%= a.title %></div>
                            <div class="event-date"><%= new Date(a.created_at).toLocaleString() %></div>
                        </div>
                    </div>
                <% }); %>
                <% if (latestAnnouncements.length > 3) { %>
                    <div class="text-center mt-2">
                        <a href="/player/announcements" class="text-sm" style="color: #1E3A8A; font-weight: 600;">Ver todos los anuncios →</a>
                    </div>
                <% } %>
            <% } else { %>
                <p class="empty-message">📭 No hay anuncios recientes</p>
            <% } %>
        </div>

        <!-- Volver -->
        <div class="mt-8 text-center">
            <a href="/player/dashboard" class="btn-volver shadow-md">← Volver al Dashboard</a>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>