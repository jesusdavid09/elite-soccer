<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil | Elite Soccer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-100">
    <%- include('../partials/navbar', { user: user }) %>

    <main class="container mx-auto px-4 py-8 max-w-md">
        <div class="bg-white rounded-xl shadow-lg p-6 border border-gray-200">
            <h1 class="text-2xl font-bold text-center text-[#1E3A8A] mb-6">👤 Mi Perfil</h1>

            <!-- Foto -->
            <div class="text-center mb-6">
                <div class="relative inline-block">
                    <div class="w-32 h-32 mx-auto bg-[#1E3A8A] rounded-full flex items-center justify-center overflow-hidden shadow-lg">
                        <% if (player && player.photo_url) { %>
                            <img src="<%= player.photo_url %>" class="w-full h-full object-cover">
                        <% } else { %>
                            <span class="text-5xl text-white">👤</span>
                        <% } %>
                    </div>
                    <form action="/player/profile/upload-photo" method="POST" enctype="multipart/form-data">
                        <input type="file" name="photo" accept="image/*" class="hidden" id="photoInput" onchange="this.form.submit()">
                        <button type="button" onclick="document.getElementById('photoInput').click()" 
                            class="absolute bottom-0 right-0 bg-[#1E3A8A] text-white p-2 rounded-full shadow-lg hover:bg-[#172554] transition">
                            📷
                        </button>
                    </form>
                </div>
                <p class="text-xs text-gray-400 mt-2">Haz clic en el icono para cambiar tu foto</p>
            </div>

            <!-- Información -->
            <div class="border-t border-gray-200 pt-4 space-y-3">
                <div class="flex justify-between items-center py-2">
                    <span class="text-gray-500 font-medium">📛 Nombre</span>
                    <span class="font-semibold"><%= player ? player.full_name : user.full_name %></span>
                </div>
                <div class="flex justify-between items-center py-2 border-t border-gray-100">
                    <span class="text-gray-500 font-medium">📧 Email</span>
                    <span class="font-semibold"><%= user.email %></span>
                </div>
                <div class="flex justify-between items-center py-2 border-t border-gray-100">
                    <span class="text-gray-500 font-medium">🔢 Número</span>
                    <span class="font-semibold text-[#1E3A8A]">#<%= player ? player.jersey_number : '?' %></span>
                </div>
                <div class="flex justify-between items-center py-2 border-t border-gray-100">
                    <span class="text-gray-500 font-medium">⚽ Posición</span>
                    <span class="font-semibold"><%= player ? player.position : 'No asignada' %></span>
                </div>
                <div class="flex justify-between items-center py-2 border-t border-gray-100">
                    <span class="text-gray-500 font-medium">📅 Edad</span>
                    <span class="font-semibold"><%= player ? player.age : '-' %> años</span>
                </div>
                <div class="flex justify-between items-center py-2 border-t border-gray-100">
                    <span class="text-gray-500 font-medium">📱 Teléfono</span>
                    <span class="font-semibold"><%= player ? (player.phone || 'No registrado') : 'No registrado' %></span>
                </div>
            </div>

            <div class="mt-6 text-center">
                <a href="/player/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white px-6 py-2 rounded-lg transition inline-block">
                    ← Volver al Dashboard
                </a>
            </div>
        </div>

        <!-- Estadísticas -->
        <% if (statistics) { %>
            <div class="bg-white rounded-xl shadow-lg p-6 mt-6 border border-gray-200">
                <h3 class="text-lg font-bold mb-4 text-center text-[#1E3A8A]">📊 Mis Estadísticas</h3>
                <div class="grid grid-cols-3 gap-3 text-center">
                    <div class="bg-blue-50 rounded-lg p-2">
                        <div class="text-xl font-bold text-[#1E3A8A]"><%= statistics.goals || 0 %></div>
                        <div class="text-xs text-gray-500">Goles</div>
                    </div>
                    <div class="bg-green-50 rounded-lg p-2">
                        <div class="text-xl font-bold text-green-600"><%= statistics.assists || 0 %></div>
                        <div class="text-xs text-gray-500">Asistencias</div>
                    </div>
                    <div class="bg-purple-50 rounded-lg p-2">
                        <div class="text-xl font-bold text-purple-600"><%= statistics.matches_played || 0 %></div>
                        <div class="text-xs text-gray-500">Partidos</div>
                    </div>
                </div>
            </div>
        <% } %>
    </main>

    <%- include('../partials/footer') %>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('success')) {
            alert('✅ Foto actualizada correctamente');
        }
    </script>
</body>
</html>