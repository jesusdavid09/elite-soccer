<!-- Vista parcial: profile.ejs (Inyectada automáticamente en el layout maestro) -->

<div class="max-w-2xl mx-auto space-y-6">
    
    <!-- Tarjeta Principal de Perfil -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 md:p-8 shadow-sm transition duration-300 hover:shadow-md">
        <h1 class="text-2xl font-bold text-center text-[#1E3A8A] mb-6 flex items-center justify-center gap-2">
            <span>👤</span> Mi Perfil
        </h1>

        <!-- Contenedor Foto de Perfil -->
        <div class="text-center mb-8">
            <div class="relative inline-block group">
                <div class="w-32 h-32 mx-auto bg-[#1E3A8A] rounded-full flex items-center justify-center overflow-hidden border-4 border-white shadow-md ring-4 ring-gray-100 transition duration-300">
                    <% if (player && player.photo_url) { %>
                        <img src="<%= player.photo_url %>" alt="<%= player.full_name %>" class="w-full h-full object-cover">
                    <% } else { %>
                        <span class="text-5xl text-white select-none">👤</span>
                    <% } %>
                </div>
                
                <!-- Formulario/Botón de subida -->
                <form action="/player/profile/upload-photo" method="POST" enctype="multipart/form-data" id="photoForm">
                    <input type="file" name="photo" accept="image/*" class="hidden" id="photoInput" onchange="document.getElementById('photoForm').submit()">
                    <button type="button" onclick="document.getElementById('photoInput').click()" 
                        class="absolute bottom-0 right-2 bg-[#1E3A8A] hover:bg-[#172554] text-white p-2.5 rounded-full shadow-lg border-2 border-white cursor-pointer transition duration-200 hover:scale-110" 
                        title="Cambiar foto">
                        📷
                    </button>
                </form>
            </div>
            <p class="text-xs text-gray-400 font-medium mt-3">Haz clic en el icono para cambiar tu foto de perfil</p>
        </div>

        <!-- Información Detallada del Jugador -->
        <div class="border-t border-gray-100 pt-2 divide-y divide-gray-50">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-3.5 gap-1">
                <span class="text-sm font-medium text-gray-500 flex items-center gap-2">📛 Nombre</span>
                <span class="text-sm font-bold text-gray-900"><%= player ? player.full_name : user.full_name %></span>
            </div>
            
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-3.5 gap-1">
                <span class="text-sm font-medium text-gray-500 flex items-center gap-2">📧 Email</span>
                <span class="text-sm font-semibold text-gray-900 break-all"><%= user.email %></span>
            </div>
            
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-3.5 gap-1">
                <span class="text-sm font-medium text-gray-500 flex items-center gap-2">🔢 Número de Camiseta</span>
                <span class="text-sm font-extrabold text-[#1E3A8A]">#<%= player ? player.jersey_number : '?' %></span>
            </div>
            
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-3.5 gap-1">
                <span class="text-sm font-medium text-gray-500 flex items-center gap-2">⚽ Posición</span>
                <span class="text-sm font-bold text-gray-900"><%= player && player.position ? player.position : 'No asignada' %></span>
            </div>
            
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-3.5 gap-1">
                <span class="text-sm font-medium text-gray-500 flex items-center gap-2">📅 Edad</span>
                <span class="text-sm font-bold text-gray-900"><%= player && player.age ? player.age + ' años' : 'No especificada' %></span>
            </div>
            
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-3.5 gap-1">
                <span class="text-sm font-medium text-gray-500 flex items-center gap-2">📱 Teléfono</span>
                <span class="text-sm font-bold text-gray-900"><%= player && player.phone ? player.phone : 'No registrado' %></span>
            </div>
            
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-3.5 gap-1">
                <span class="text-sm font-medium text-gray-500 flex items-center gap-2">📅 Fecha de Registro</span>
                <span class="text-sm font-bold text-gray-900">
                    <%= player && player.created_at ? new Date(player.created_at).toLocaleDateString('es-CO', { dateStyle: 'medium' }) : 'No disponible' %>
                </span>
            </div>
        </div>

        <!-- Botón Volver -->
        <div class="mt-8 text-center">
            <a href="/player/dashboard" class="bg-[#1E3A8A] hover:bg-[#172554] text-white font-semibold px-6 py-2.5 rounded-xl transition duration-200 active:scale-98 inline-flex items-center gap-2 shadow-sm text-sm">
                ← Volver al Dashboard
            </a>
        </div>
    </div>

    <!-- Panel de Estadísticas del Jugador -->
    <% if (statistics) { %>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm transition duration-300 hover:shadow-md">
            <h2 class="text-base font-bold text-[#1E3A8A] mb-4 text-center flex items-center justify-center gap-2">
                <span>📊</span> Rendimiento en la Temporada
            </h2>
            <div class="grid grid-cols-3 gap-4">
                <div class="bg-blue-50/50 border border-blue-100 rounded-xl p-3 text-center transition duration-200 hover:-translate-y-0.5 hover:shadow-sm">
                    <div class="text-xl md:text-2xl font-black text-[#1E3A8A]"><%= statistics.goals || 0 %></div>
                    <div class="text-[11px] md:text-xs font-semibold text-gray-500 mt-1">⚽ Goles</div>
                </div>
                
                <div class="bg-emerald-50/50 border border-emerald-100 rounded-xl p-3 text-center transition duration-200 hover:-translate-y-0.5 hover:shadow-sm">
                    <div class="text-xl md:text-2xl font-black text-emerald-700"><%= statistics.assists || 0 %></div>
                    <div class="text-[11px] md:text-xs font-semibold text-gray-500 mt-1">🎯 Asistencias</div>
                </div>
                
                <div class="bg-purple-50/50 border border-purple-100 rounded-xl p-3 text-center transition duration-200 hover:-translate-y-0.5 hover:shadow-sm">
                    <div class="text-xl md:text-2xl font-black text-purple-700"><%= statistics.matches_played || 0 %></div>
                    <div class="text-[11px] md:text-xs font-semibold text-gray-500 mt-1"> Stadium Partidos</div>
                </div>
            </div>
        </div>
    <% } %>

    <!-- Gestión del Estado de Cuenta -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
        <h2 class="text-base font-bold text-[#1E3A8A] mb-4 text-center flex items-center justify-center gap-2">
            <span>🔐</span> Credenciales y Estado
        </h2>
        <div class="divide-y divide-gray-50">
            <div class="flex justify-between items-center py-3">
                <span class="text-sm font-medium text-gray-500">Rol asignado</span>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-[#1E3A8A] text-white">
                    <%= user.role === 'coach' ? 'Entrenador' : 'Jugador' %>
                </span>
            </div>
            
            <div class="flex justify-between items-center py-3">
                <span class="text-sm font-medium text-gray-500">Estado de Membresía</span>
                <% if (player && player.status === 'approved') { %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800">
                        ✅ Aprobado
                    </span>
                <% } else if (player && player.status === 'pending') { %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-amber-100 text-amber-900">
                        ⏳ Pendiente
                    </span>
                <% } else if (player && player.status === 'rejected') { %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">
                        ❌ Rechazado
                    </span>
                <% } else { %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-amber-100 text-amber-900">
                        ⏳ Pendiente
                    </span>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Lógica de Notificaciones de Feedback -->
<script>
    (function() {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('success')) {
            alert('✅ Foto de perfil actualizada correctamente.');
        }
        if (urlParams.get('error')) {
            alert('❌ Error al actualizar la foto. Por favor, intenta de nuevo.');
        }
    })();
</script>